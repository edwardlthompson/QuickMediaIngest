<Window x:Class="QuickMediaIngest.ImportHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import History" Height="480" Width="720" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Foreground="{DynamicResource MaterialDesignBody}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Import History" Style="{StaticResource AppHeadingTextStyle}" FontSize="18"/>

        <ListView Grid.Row="1" ItemsSource="{Binding ImportHistoryRecords}" Margin="0,8,0,8"
                  Background="{DynamicResource MaterialDesignPaper}"
                  BorderBrush="{DynamicResource MaterialDesignDivider}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Started" Width="180" DisplayMemberBinding="{Binding StartedAtDisplay}"/>
                    <GridViewColumn Header="Summary" Width="420" DisplayMemberBinding="{Binding SummaryDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Margin="6" Content="Export" Command="{Binding ExportImportHistoryCommand}" Style="{StaticResource MaterialDesignRaisedButton}"/>
            <Button Width="90" Margin="6" Content="Clear" Click="Clear_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
            <Button Width="90" Margin="6" Click="Close_Click" Style="{StaticResource MaterialDesignRaisedButton}">Close</Button>
        </StackPanel>
    </Grid>
</Window>