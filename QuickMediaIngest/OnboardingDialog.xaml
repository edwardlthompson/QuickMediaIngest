<Window x:Class="QuickMediaIngest.OnboardingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Quick Media Ingest!" Height="470" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="False"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Border Background="{DynamicResource MaterialDesignPaper}" CornerRadius="12" Padding="32" Margin="12"
            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                       Width="72" Height="72"
                       Margin="0,0,0,12"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
                <TextBlock Text="Welcome to Quick Media Ingest!" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" TextAlignment="Center"/>
                <TextBlock Text="• Use the sidebar to add SD cards or FTP sources.
• Use the Import button to start ingesting.
• Try the dark/light toggle in the top bar.
• Tooltips and keyboard shortcuts are available throughout the app.

You can revisit this tour from Settings > About."
                           FontSize="15" TextWrapping="Wrap" Margin="0,0,0,24" TextAlignment="Left"/>
                <Button Content="Got it!" Width="120" Height="38" FontWeight="SemiBold" Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="GotIt_Click" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
