<Window x:Class="QuickMediaIngest.OnboardingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:QuickMediaIngest.Localization"
        Title="{loc:Loc Onboarding_Title}" Height="470" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="False"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Border Background="{DynamicResource MaterialDesignPaper}" CornerRadius="12" Padding="32" Margin="12"
            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                       Width="72" Height="72"
                       Margin="0,0,0,12"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
                <TextBlock Text="{loc:Loc Onboarding_Title}" Style="{StaticResource AppHeadingLargeTextStyle}" Margin="0,0,0,16" TextAlignment="Center"/>
                <TextBlock Text="{loc:Loc Onboarding_Body}"
                           Style="{StaticResource AppBodyTextStyle}" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,24" TextAlignment="Left"/>
                <Button Content="{loc:Loc Onboarding_GotIt}" Width="120" Height="38" FontWeight="SemiBold" Style="{StaticResource DialogPrimaryButtonStyle}"
                        Click="GotIt_Click" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
