<Window x:Class="QuickMediaIngest.OnboardingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Quick Media Ingest!" Height="380" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="32" Margin="12">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Welcome to Quick Media Ingest!" FontSize="22" FontWeight="Bold" Foreground="#222" Margin="0,0,0,16" TextAlignment="Center"/>
                <TextBlock Text="• Use the sidebar to add SD cards or FTP sources.
• Use the Import button to start ingesting.
• Try the dark/light toggle in the top bar.
• Tooltips and keyboard shortcuts are available throughout the app.

You can revisit this tour from Settings > About."
                           FontSize="15" Foreground="#444" TextWrapping="Wrap" Margin="0,0,0,24" TextAlignment="Left"/>
                <Button Content="Got it!" Width="120" Height="38" FontWeight="SemiBold" Background="#2A5FFF" Foreground="White"
                        Click="GotIt_Click" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
