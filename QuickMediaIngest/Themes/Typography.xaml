<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Reference brushes dictionary -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Brushes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ============ FONT FAMILY ============ -->
    <FontFamily x:Key="Theme.FontFamilyDefault">Segoe UI</FontFamily>
    <FontFamily x:Key="Theme.FontFamilyMono">Consolas</FontFamily>
    
    <!-- ============ HEADER STYLES ============ -->
    
    <Style x:Key="Theme.HeaderBarTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Theme.FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary.Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    
    <Style x:Key="Theme.SectionHeaderTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Theme.FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary.Brush}"/>
    </Style>

    <!-- ============ BODY TEXT STYLES ============ -->
    
    <Style x:Key="Theme.BodyTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Theme.FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.TextSecondary.Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    
    <Style x:Key="Theme.CaptionTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Theme.FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.TextTertiary.Brush}"/>
    </Style>
    
    <!-- ============ LABEL STYLES (for form fields) ============ -->
    
    <Style x:Key="Theme.ControlLabelTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Theme.FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource Theme.TextSecondary.Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

</ResourceDictionary>
