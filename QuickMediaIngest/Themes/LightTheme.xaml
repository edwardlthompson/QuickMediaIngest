<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ LIGHT THEME ACTIVE COLORS ============ -->
    <!-- These override the Theme.* keys to apply light theme -->
    
    <!-- Primary backgrounds -->
    <Color x:Key="Theme.Background">#FFFFFF</Color>
    <Color x:Key="Theme.Surface">#F5F5F5</Color>
    <Color x:Key="Theme.BarBackground">#F5F5F5</Color>
    <Color x:Key="Theme.CardBackground">#FAFAFA</Color>
    
    <!-- Text colors -->
    <Color x:Key="Theme.TextPrimary">#212121</Color>
    <Color x:Key="Theme.TextSecondary">#424242</Color>
    <Color x:Key="Theme.TextTertiary">#757575</Color>
    
    <!-- Accent colors -->
    <Color x:Key="Theme.Accent">#0078D4</Color>
    <Color x:Key="Theme.AccentLight">#5CB3E0</Color>
    
    <!-- UI Elements -->
    <Color x:Key="Theme.Divider">#BDBDBD</Color>
    <Color x:Key="Theme.Hover">#EEEEEE</Color>
    <Color x:Key="Theme.Border">#CCCCCC</Color>
    <Color x:Key="Theme.Success">#4CAF50</Color>
    <Color x:Key="Theme.Warning">#FFA500</Color>
    <Color x:Key="Theme.Error">#F44336</Color>
    <Color x:Key="Theme.ExcelYellow">#FFD700</Color>

</ResourceDictionary>
