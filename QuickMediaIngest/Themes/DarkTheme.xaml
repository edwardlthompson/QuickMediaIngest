<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ DARK THEME ACTIVE COLORS ============ -->
    <!-- These override the Theme.* keys to apply dark theme -->
    
    <!-- Primary backgrounds -->
    <Color x:Key="Theme.Background">#1E1E1E</Color>
    <Color x:Key="Theme.Surface">#2D2D30</Color>
    <Color x:Key="Theme.BarBackground">#2D2D30</Color>
    <Color x:Key="Theme.CardBackground">#252526</Color>
    
    <!-- Text colors -->
    <Color x:Key="Theme.TextPrimary">#FFFFFF</Color>
    <Color x:Key="Theme.TextSecondary">#E0E0E0</Color>
    <Color x:Key="Theme.TextTertiary">#999999</Color>
    
    <!-- Accent colors - Excel 2003 iconic blue -->
    <Color x:Key="Theme.Accent">#007ACC</Color>
    <Color x:Key="Theme.AccentLight">#1084D7</Color>
    
    <!-- UI Elements -->
    <Color x:Key="Theme.Divider">#3F3F46</Color>
    <Color x:Key="Theme.Hover">#3E3E42</Color>
    <Color x:Key="Theme.Border">#3F3F46</Color>
    <Color x:Key="Theme.Success">#4CAF50</Color>
    <Color x:Key="Theme.Warning">#FFA500</Color>
    <Color x:Key="Theme.Error">#F44336</Color>
    <Color x:Key="Theme.ExcelYellow">#FFEB3B</Color>

</ResourceDictionary>
