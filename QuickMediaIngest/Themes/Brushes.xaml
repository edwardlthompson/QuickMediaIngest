<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Reference color dictionary -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ============ BRUSHES ============ -->
    
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Theme.Background.Brush" Color="{DynamicResource Theme.Background}"/>
    <SolidColorBrush x:Key="Theme.Surface.Brush" Color="{DynamicResource Theme.Surface}"/>
    <SolidColorBrush x:Key="Theme.BarBackground.Brush" Color="{DynamicResource Theme.BarBackground}"/>
    <SolidColorBrush x:Key="Theme.CardBackground.Brush" Color="{DynamicResource Theme.CardBackground}"/>
    
    <!-- Text -->
    <SolidColorBrush x:Key="Theme.TextPrimary.Brush" Color="{DynamicResource Theme.TextPrimary}"/>
    <SolidColorBrush x:Key="Theme.TextSecondary.Brush" Color="{DynamicResource Theme.TextSecondary}"/>
    <SolidColorBrush x:Key="Theme.TextTertiary.Brush" Color="{DynamicResource Theme.TextTertiary}"/>
    
    <!-- Accents -->
    <SolidColorBrush x:Key="Theme.Accent.Brush" Color="{DynamicResource Theme.Accent}"/>
    <SolidColorBrush x:Key="Theme.AccentLight.Brush" Color="{DynamicResource Theme.AccentLight}"/>
    
    <!-- UI Elements -->
    <SolidColorBrush x:Key="Theme.Divider.Brush" Color="{DynamicResource Theme.Divider}"/>
    <SolidColorBrush x:Key="Theme.Hover.Brush" Color="{DynamicResource Theme.Hover}"/>
    <SolidColorBrush x:Key="Theme.Border.Brush" Color="{DynamicResource Theme.Border}"/>
    <SolidColorBrush x:Key="Theme.Success.Brush" Color="{DynamicResource Theme.Success}"/>
    <SolidColorBrush x:Key="Theme.Warning.Brush" Color="{DynamicResource Theme.Warning}"/>
    <SolidColorBrush x:Key="Theme.Error.Brush" Color="{DynamicResource Theme.Error}"/>
    <SolidColorBrush x:Key="Theme.ExcelYellow.Brush" Color="{DynamicResource Theme.ExcelYellow}"/>

</ResourceDictionary>
