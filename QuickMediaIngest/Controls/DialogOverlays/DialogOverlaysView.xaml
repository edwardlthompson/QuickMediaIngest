<UserControl x:Class="QuickMediaIngest.Controls.DialogOverlaysView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuickMediaIngest"
    xmlns:models="clr-namespace:QuickMediaIngest.Core.Models"
    xmlns:loc="clr-namespace:QuickMediaIngest.Localization"
    xmlns:vm="clr-namespace:QuickMediaIngest.ViewModels"
    xmlns:converters="clr-namespace:QuickMediaIngest.Converters"
    xmlns:behaviors="clr-namespace:QuickMediaIngest.Controls.Behaviors"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
    <Grid x:Name="AddFtpOverlay" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowAddFtpDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Ftp_AddSourceTitle}" Style="{StaticResource AppHeadingTextStyle}" FontSize="16" Margin="0,0,0,12"/>

                    <TextBlock Text="{loc:Loc Ftp_Host}" Style="{StaticResource AppBodyTextStyle}"/>
                    <TextBox Text="{Binding FtpHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <StackPanel Width="120">
                            <TextBlock Text="{loc:Loc Ftp_Port}" Style="{StaticResource AppBodyTextStyle}"/>
                            <TextBox Text="{Binding FtpPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="{loc:Loc Ftp_User}" Style="{StaticResource AppBodyTextStyle}"/>
                            <TextBox Text="{Binding FtpUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" Width="300" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{loc:Loc Ftp_Password}" Style="{StaticResource AppBodyTextStyle}" Margin="0,6,0,0"/>
                    <PasswordBox PasswordChar="●" behaviors:PasswordBoxAssist.BoundPassword="{Binding FtpPass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="{loc:Loc Ftp_PasswordVaultHint}" Style="{StaticResource AppCaptionTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                    <TextBlock Text="{loc:Loc Ftp_RemoteFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,6,0,0"/>
                    <TextBox Text="{Binding FtpRemoteFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                    <TextBlock Text="" Height="6"/>
                    <TextBlock Text="{Binding FtpDialogStatusMessage}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{loc:Loc Btn_Test}" Command="{Binding TestFtpConnectionCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Settings_Browse}" Command="{Binding BrowseFtpFoldersCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Btn_Save}" Command="{Binding SaveFtpCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Btn_Cancel}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowDriveSelectionDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="910">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{loc:Loc DriveSelect_Title}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc DriveSelect_Description}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ListBox ItemsSource="{Binding DriveSelectionItems}" MaxHeight="280">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" Style="{StaticResource AppBodyTextStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DriveType}" Style="{StaticResource AppCaptionTextStyle}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{loc:Loc DriveSelect_SaveAndScan}" Command="{Binding ConfirmDriveSelectionCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Btn_Cancel}" Command="{Binding CancelDriveSelectionCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    <!-- Settings overlay placeholder moved to end of root Grid (render on top) -->
    <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Border Width="760" Padding="18" CornerRadius="8"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{Binding ScanDialogTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ScanProgressPercent}" Margin="0,0,0,10"/>

                <TextBlock Text="{Binding ScanProgressMessage}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="{loc:Loc Scan_CurrentFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentScanFolder}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="{loc:Loc Scan_FilesFoundInFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentScanFolderTotalFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{loc:Loc Scan_FilesProcessedInFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentScanFolderProcessedFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="{loc:Loc Scan_ScannedFolders}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ScannedFolders}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="{loc:Loc Scan_TotalFolders}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding TotalFoldersToScan}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="{loc:Loc Scan_ScannedFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ScannedFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Scan_TotalFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding TotalFilesToScan}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowImportProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Border Width="760" Padding="18" CornerRadius="8"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{loc:Loc Import_InProgressTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{loc:Loc Import_OverallProgress}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ProgressPercent}" Style="{StaticResource AppBodyTextStyle}"/>
                    <TextBlock Text="%" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Border Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Import_CurrentGroup}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentImportGroupTitle}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Import_FilesProcessed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{Binding ProcessedFilesForImport}"/>
                            <TextBlock Text="/"/>
                            <TextBlock Text="{Binding TotalFilesForImport}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Import_Succeeded}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentFileBeingImported}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Import_Failed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FailedFilesForImport}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc Import_Elapsed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportElapsedText}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc Import_EtaSpeed}" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc About_Eta}"/>
                            <TextBlock Text="{Binding ImportEtaText}"/>
                            <TextBlock Text="  |  "/>
                            <TextBlock Text="{Binding ImportDataRateText}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="{loc:Loc Import_CurrentGroupProgress}" Style="{StaticResource AppBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ProgressBar Height="12" Minimum="0" Maximum="100" Value="{Binding CurrentGroupProgressPercent}" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc Import_GroupFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentGroupFileBeingImported}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc Import_GroupTotal}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TotalFilesInCurrentGroup}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{loc:Loc Import_OverallTotalFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TotalFilesForImport}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc Import_FailedInLastRun}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding FailedImportRecords.Count}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Loc Import_QueuedJobs}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding QueuedImportCount}" Style="{StaticResource AppBodyTextStyle}"/>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding FailedImportRecords}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" Style="{StaticResource AppCaptionTextStyle}" Foreground="{DynamicResource Theme.Error.Brush}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="{loc:Loc Btn_CancelImport}"
                            Command="{Binding CancelActiveImportCommand}"
                            Visibility="{Binding IsImporting, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource DialogOutlinedButtonStyle}"
                            Padding="14,6"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowSkippedFoldersDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding SkippedFoldersReportTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                    <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding SkippedFoldersReportText}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                    </ScrollViewer>
                    <CheckBox Margin="0,12,0,0"
                              Visibility="{Binding ShowSkippedFoldersSuppressReminderOption, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Content="{loc:Loc SkippedFolders_DontRemindExcluded}"
                              IsChecked="{Binding SuppressExcludedFolderScanReminders, Mode=TwoWay}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{loc:Loc Btn_Copy}" Command="{Binding CopySkippedFoldersReportCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Btn_Close}" Command="{Binding CloseSkippedFoldersReportCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    <!-- About dialog overlay (includes update checking) -->
    <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowAboutDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="950">
        <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush Visual="{Binding BlurBackdropSource, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Stretch="Fill"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <BlurEffect Radius="14" RenderingBias="Performance"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="640" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{loc:Loc About_Title}" Style="{StaticResource AppHeadingTextStyle}" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc About_Description}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc About_Glossary}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{loc:Loc About_Glossary_TermPreflight}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Loc About_Glossary_DefPreflight}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Loc About_Glossary_TermUnified}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Loc About_Glossary_DefUnified}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Loc About_Glossary_TermShoot}" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Loc About_Glossary_DefShoot}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{loc:Loc About_Version}" FontWeight="SemiBold" Width="120"/>
                        <TextBlock Text="{Binding AppVersion}"/>
                    </StackPanel>

                    <Separator Margin="0,12,0,12" />

                    <TextBlock Text="{loc:Loc About_UpdateChecking}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc About_Package}" Width="120" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding PackageTypeOptions}" SelectedItem="{Binding UpdatePackageType}" Width="160" />
                        <TextBlock Text="{loc:Loc About_Interval}" Width="100" Margin="16,0,0,0" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding UpdateIntervalHours}" SelectedValuePath="Hours" DisplayMemberPath="Display" Width="160" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <Button Content="{loc:Loc About_CheckUpdatesNow}" Command="{Binding RefreshUpdateCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc About_DownloadUpdate}" Command="{Binding DownloadUpdateCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                    </StackPanel>

                    <TextBlock Text="" Height="8"/>
                    <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                        <ProgressBar Minimum="0" Maximum="100" Height="14" Width="520" Value="{Binding UpdateProgress}" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ProgressBar IsIndeterminate="True" Height="14" Width="520" Visibility="{Binding IsCheckingForUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc About_Speed}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UpdateDownloadSpeedText}" Margin="0,0,12,0" />
                            <TextBlock Text="{loc:Loc About_Eta}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding UpdateDownloadEtaText}" />
                        </StackPanel>
                    </StackPanel>
                    <Separator Margin="0,12,0,12" />
                    <TextBlock Text="{loc:Loc About_Diagnostics}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <Button Content="{loc:Loc About_OpenLogsFolder}" Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{loc:Loc About_ReportBug}" Command="{Binding ReportBugCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{loc:Loc About_Changelog}" Command="{Binding OpenChangelogCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{loc:Loc About_Releases}" Command="{Binding OpenGitHubCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{loc:Loc About_Version}" FontWeight="SemiBold" Width="80"/>
                        <TextBlock Text="{Binding AppVersion}" Width="120"/>
                        <TextBlock Text="{loc:Loc About_BuildDate}" FontWeight="SemiBold" Width="80"/>
                        <TextBlock Text="{Binding BuildDate}" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{loc:Loc Btn_Close}" Command="{Binding ToggleAboutCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</UserControl>
