<Window x:Class="QuickMediaIngest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quick Media Ingest" Height="600" Width="900"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Sources -->
        <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Sources" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="16" FontWeight="Bold"/>
                
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <!-- Sidebar items will go here -->
                        <materialDesign:Card Margin="8" Padding="12">
                            <TextBlock Text="📷 SD Card (E:)" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </materialDesign:Card>
                        <materialDesign:Card Margin="8" Padding="12">
                            <TextBlock Text="📱 Phone (FTP)" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
                
                <Button Grid.Row="2" Content="Add FTP Source" Margin="16" Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Top Controls -->
            <StackPanel Orientation="Horizontal" Margin="16">
                <TextBox materialDesign:HintAssist.Hint="Album Name" Width="300" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="{Binding AlbumName, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Import" Margin="16,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding ImportCommand}"/>
            </StackPanel>
            
            <!-- Thumbnail Grid -->
            <ScrollViewer Grid.Row="1" Margin="8">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Width="200" Height="150" Margin="8" Padding="12" materialDesign:ElevationAssist.Elevation="Dp2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontSize="16" FontWeight="Bold"/>
                                    
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StartDate, StringFormat='{}Start: {0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        <TextBlock Text="{Binding EndDate, StringFormat='{}End: {0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <materialDesign:PackIcon Kind="ImageMultiple" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Items.Count}" FontWeight="Bold"/>
                                        <TextBlock Text=" items" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Status Bar -->
            <StatusBar Grid.Row="2" Background="{DynamicResource MaterialDesignDarkBackground}">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" Margin="4,0,16,0"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <ProgressBar Value="{Binding ProgressPercent}" Width="150" Height="10" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryLightMidBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
