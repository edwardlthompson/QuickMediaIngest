<Window x:Class="QuickMediaIngest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuickMediaIngest"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Quick Media Ingest" Height="620" Width="960"
    Icon="QuickMediaIngest.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Background="{DynamicResource MaterialDesignPaper}"
    PreviewMouseWheel="Window_PreviewMouseWheel"
    PreviewKeyDown="Window_PreviewKeyDown"
    SizeChanged="Window_SizeChanged"
    StateChanged="Window_StateChanged"
    Closing="Window_Closing">
    <Window.InputBindings>
        <KeyBinding Key="I" Modifiers="Control" Command="{Binding ImportCommand}" />
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Inverted Boolean to Boolean Converter for disabling during import -->
        <local:InvertBoolConverter x:Key="BoolToInvertedBoolConverter" />
        
        <!-- Text Converter for Import Button -->
        <local:BoolToImportingTextConverter x:Key="ImportingTextConverter" />

        <Style x:Key="FtpInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="SelectionBrush" Value="#FFE600"/>
            <Setter Property="SelectionOpacity" Value="0.95"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_SelectAll"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Overlays (dialogs, notifications) -->
        <Grid x:Name="AddFtpOverlay" Grid.ColumnSpan="2" Background="{DynamicResource Theme.Hover.Brush}" Visibility="{Binding ShowAddFtpDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900" Loaded="AddFtpOverlay_Loaded" Unloaded="AddFtpOverlay_Unloaded">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Add FTP Source" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                        <TextBlock Text="Host" FontSize="12"/>
                        <TextBox Text="{Binding FtpHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <StackPanel Width="120">
                                <TextBlock Text="Port" FontSize="12"/>
                                <TextBox Text="{Binding FtpPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="User" FontSize="12"/>
                                <TextBox Text="{Binding FtpUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" Width="300" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Password" FontSize="12" Margin="0,6,0,0"/>
                        <PasswordBox PasswordChar="●" PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBlock Text="Remote Folder" FontSize="12" Margin="0,6,0,0"/>
                        <TextBox Text="{Binding FtpRemoteFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                        <TextBlock Text="" Height="6"/>
                        <TextBlock Text="{Binding FtpDialogStatusMessage}" Foreground="{DynamicResource MaterialDesignBody}" FontSize="12" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="Test" Command="{Binding TestFtpConnectionCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                            <Button Content="Browse" Command="{Binding BrowseFtpFoldersCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                            <Button Content="Save" Command="{Binding SaveFtpCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                            <Button Content="Cancel" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- Settings overlay placeholder moved to end of root Grid (render on top) -->
        <Grid Grid.ColumnSpan="2" Background="{DynamicResource Theme.Hover.Brush}" Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <Border Width="760" Padding="18" CornerRadius="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding ScanDialogTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ScanProgressPercent}" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ScanProgressMessage}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CurrentScanFolder, StringFormat='Current Folder: {0}'}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentScanFolderTotalFiles, StringFormat='Files Found In Folder: {0}'}" FontSize="12" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding CurrentScanFolderProcessedFiles, StringFormat='Files Processed In Folder: {0}'}" FontSize="12" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ScannedFolders, StringFormat='Scanned Folders: {0}'}" FontSize="12" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding TotalFoldersToScan, StringFormat='Total Folders: {0}'}" FontSize="12" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding ScannedFiles, StringFormat='Scanned Files: {0}'}" FontSize="12" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding TotalFilesToScan, StringFormat='Total Files: {0}'}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.ColumnSpan="2" Background="{DynamicResource Theme.Hover.Brush}" Visibility="{Binding ShowImportProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <Border Width="760" Padding="18" CornerRadius="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Import In Progress..." FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ProgressPercent, StringFormat='Overall Progress: {0}%'}" FontSize="12" Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Current Group:" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentImportGroupTitle}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Files Processed:" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="{Binding ProcessedFilesForImport}"/>
                                <TextBlock Text="/"/>
                                <TextBlock Text="{Binding TotalFilesForImport}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Succeeded:" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentFileBeingImported}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Failed:" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FailedFilesForImport}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Elapsed:" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportElapsedText}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="ETA / Speed:" FontWeight="SemiBold"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="ETA "/>
                                <TextBlock Text="{Binding ImportEtaText}"/>
                                <TextBlock Text="  |  "/>
                                <TextBlock Text="{Binding ImportDataRateText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Current Group Progress" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ProgressBar Height="12" Minimum="0" Maximum="100" Value="{Binding CurrentGroupProgressPercent}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentGroupFileBeingImported, StringFormat='Group Files: {0}'}" FontSize="12"/>
                    <TextBlock Text="{Binding TotalFilesInCurrentGroup, StringFormat='Group Total: {0}'}" FontSize="12"/>
                    <TextBlock Text="{Binding TotalFilesForImport, StringFormat='Overall Total Files: {0}'}" FontSize="12" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding FailedImportRecords.Count, StringFormat='Failed In Last Run: {0}'}" FontSize="12"/>
                    <TextBlock Text="{Binding QueuedImportCount, StringFormat='Queued Jobs: {0}'}" FontSize="12"/>
                    <ItemsControl ItemsSource="{Binding FailedImportRecords}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="{DynamicResource Theme.Error.Brush}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.ColumnSpan="2" Background="{DynamicResource Theme.Hover.Brush}" Visibility="{Binding ShowSkippedFoldersDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <!-- ...existing Skipped Folders dialog content... -->
        </Grid>
        <!-- About dialog overlay (includes update checking) -->
        <Grid Grid.ColumnSpan="2" Background="{DynamicResource Theme.Hover.Brush}" Visibility="{Binding ShowAboutDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="950">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="640" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="About Quick Media Ingest" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="A small utility to quickly import photos and videos from phones and cameras." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Version:" FontWeight="SemiBold" Width="120"/>
                            <TextBlock Text="{Binding AppVersion}"/>
                        </StackPanel>

                        <Separator Margin="0,12,0,12" />

                        <TextBlock Text="Update Checking" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="Package:" Width="120" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding PackageTypeOptions}" SelectedItem="{Binding UpdatePackageType}" Width="160" />
                            <TextBlock Text="Interval:" Width="100" Margin="16,0,0,0" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding UpdateIntervalHours}" SelectedValuePath="Hours" DisplayMemberPath="Display" Width="160" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="Check for Updates Now" Command="{Binding RefreshUpdateCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                            <Button Content="Download Update" Command="{Binding DownloadUpdateCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="" Height="8"/>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                            <ProgressBar Minimum="0" Maximum="100" Height="14" Width="520" Value="{Binding UpdateProgress}" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ProgressBar IsIndeterminate="True" Height="14" Width="520" Visibility="{Binding IsCheckingForUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{Binding UpdateStatus}" FontSize="12" Foreground="{DynamicResource MaterialDesignBody}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Speed: " FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UpdateDownloadSpeedText}" Margin="0,0,12,0" />
                                <TextBlock Text="ETA: " FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UpdateDownloadEtaText}" />
                            </StackPanel>
                        </StackPanel>
                        <Separator Margin="0,12,0,12" />
                        <TextBlock Text="Diagnostics" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="📂 Open Logs Folder" Click="OpenLogs_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
                            <Button Content="🐛 Report a Bug" Click="ReportBug_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Version:" FontWeight="SemiBold" Width="80"/>
                            <TextBlock Text="{Binding AppVersion}" Width="120"/>
                            <TextBlock Text="Build Date:" FontWeight="SemiBold" Width="80"/>
                            <TextBlock Text="{Binding BuildDate}" Width="120"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Close" Command="{Binding ToggleAboutCommand}" Style="{StaticResource MaterialDesignFlatButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <Border Background="{DynamicResource Theme.Success.Brush}" Padding="6" CornerRadius="4" Margin="16,16,16,8" Visibility="{Binding ShowSuccessNotification, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="950">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="CheckCircle" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Theme.TextPrimary.Brush}"/>
                <TextBlock Text="Import successful! Files have been added to your destination folder." VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextPrimary.Brush}" FontWeight="Bold" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Main layout: Sidebar + Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="190" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quick Media Ingest" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource MenuForegroundBrush}"/>
                            <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="12" Foreground="{DynamicResource SidebarVersion}" Margin="0,4,0,0" />
                        </StackPanel>
                        <ToggleButton x:Name="ThemeToggle" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top" Style="{StaticResource PillToggleStyle}" Checked="PillToggle_Toggled" Unchecked="PillToggle_Toggled" />
                    </Grid>

                    <!-- Top content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel x:Name="RibbonTilePanel" Orientation="Horizontal" AllowDrop="True" Margin="12,8,12,8" VerticalAlignment="Top"
                                        DragOver="RibbonTilePanel_DragOver" Drop="RibbonTilePanel_Drop" DragLeave="RibbonTilePanel_DragLeave" />

                            <TextBlock Text="Sources" Margin="16,8,16,2" FontWeight="SemiBold" Foreground="{DynamicResource MenuForegroundBrush}" />
                            <ListBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" Margin="12,0,12,12"
                                     VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     MaxHeight="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <materialDesign:PackIcon Kind="SourceBranch" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom Settings menu -->
                    <Expander Grid.Row="2" Margin="8,8,8,12" IsExpanded="{Binding SettingsMenuExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                        <Expander.Header>
                            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource MenuForegroundBrush}" />
                        </Expander.Header>
                        <StackPanel>
                            <Button Content="Preferences" Margin="8,2,0,2" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding ToggleSettingsCommand}" />
                            <Button Content="Add FTP Source" Margin="8,2,0,2" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding ToggleAddFtpCommand}" />
                            <Button Content="Import History" Margin="8,2,0,2" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding OpenImportHistoryCommand}" />
                            <Button Content="About &amp; Updates" Margin="8,2,0,2" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding ToggleAboutCommand}" />
                        </StackPanel>
                    </Expander>
                </Grid>
            </Border>

            <!-- Sidebar resizer -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Main Content -->
            <Grid Grid.Column="2" Background="{DynamicResource MaterialDesignPaper}" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Wrapping top banner controls -->
                <Border Grid.Row="0"
                        Background="{DynamicResource MenuBackgroundBrush}"
                        BorderBrush="{DynamicResource MenuForegroundBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <WrapPanel VerticalAlignment="Center" ItemHeight="30">
                        <Button Command="{Binding ImportCommand}" Margin="0,0,10,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Start import for selected photos">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Download" Width="14" Height="14" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,4,0"/>
                                <TextBlock Text="Import" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding QueueImportCommand}" Margin="0,0,10,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Queue selected files for import">
                            <TextBlock Text="Queue"/>
                        </Button>
                        <Button Command="{Binding PreflightImportCommand}" Margin="0,0,10,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Run dry-run preflight report">
                            <TextBlock Text="Preflight"/>
                        </Button>
                        <Button Command="{Binding RetryFailedImportsCommand}" Margin="0,0,12,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Retry failed files from last import">
                            <TextBlock Text="Retry Failed"/>
                        </Button>
                        <Button Command="{Binding ResumePendingImportCommand}" Margin="0,0,12,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Resume pending import plan">
                            <TextBlock Text="Resume Pending"/>
                        </Button>
                        <Button Command="{Binding RefreshAllSourcesCommand}" Margin="0,0,12,6" Height="26" Padding="8,0"
                                Style="{StaticResource MaterialDesignFlatButton}" ToolTip="Rescan drives and refresh unified">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,4,0"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </Button>
                        <CheckBox x:Name="SelectAllCheckBox" Content="Select All" VerticalAlignment="Center" Margin="0,0,16,6" Checked="SelectAllCheckBox_Checked" Unchecked="SelectAllCheckBox_Unchecked" ToolTip="Select or deselect all shoots"/>
                        <CheckBox x:Name="DeleteAfterImportCheckBox" Content="Delete After Import" VerticalAlignment="Center" Margin="0,0,16,6"
                                  Foreground="Red" FontWeight="SemiBold" IsChecked="{Binding DeleteAfterImport, Mode=TwoWay}"
                                  Checked="DeleteAfterImportCheckBox_Checked" ToolTip="Delete originals after verified import"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,6">
                            <TextBlock Text="Group by:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider x:Name="HourIntervalSlider" Minimum="1" Maximum="24" Width="110"
                                    Value="{Binding TimeBetweenShootsHours, Mode=TwoWay}" SmallChange="1" IsSnapToTickEnabled="True" ToolTip="Adjust shoot grouping gap in hours"/>
                            <Border Background="{DynamicResource MenuForegroundBrush}" CornerRadius="4" Margin="6,0,0,0" Padding="5,2">
                                <TextBlock Text="{Binding ElementName=HourIntervalSlider, Path=Value, StringFormat={}{0}h}"
                                           Foreground="{DynamicResource MenuBackgroundBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.85" Margin="0,0,4,0"/>
                            <materialDesign:PackIcon Kind="Minus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                            <Slider x:Name="ThumbnailZoomSlider" Minimum="50" Maximum="300" Width="120"
                                    Value="{Binding ThumbnailSize, Mode=TwoWay}" Margin="5,0" ToolTip="Adjust thumbnail size"/>
                            <materialDesign:PackIcon Kind="Plus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,6">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="140" Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/>
                            <ComboBox Width="90" ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding FilterFileType, Mode=TwoWay}"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- Grouped Import Items List -->
                <ListView Grid.Row="1" ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" Margin="24" Name="GroupsListView" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12" HorizontalAlignment="Stretch" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="6" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" FontSize="15" BorderThickness="0,0,0,1" Margin="0,0,8,0"
                                                 GotKeyboardFocus="TextBox_SelectAll"
                                                 PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                                                 materialDesign:HintAssist.Hint="Enter Shoot Name"/>
                                        <CheckBox Grid.Column="1" Content="Select Shoot" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,0,10,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding FolderPath, StringFormat='Source Folder: {0}'}" FontSize="12" Foreground="{DynamicResource Theme.TextSecondary.Brush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding StartDate, StringFormat='Start: {0:yyyy-MM-dd HH:mm}'}" FontSize="12"/>
                                            <TextBlock Text="{Binding EndDate, StringFormat='End: {0:yyyy-MM-dd HH:mm}'}" FontSize="12"/>
                                            <TextBlock Text="{Binding Items.Count, StringFormat='Files: {0}'}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                    <Separator Margin="0,4,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,8,8" Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4" Padding="2">
                                                        <Image Source="{Binding Thumbnail}"
                                                               MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               Stretch="Uniform"
                                                               SnapsToDevicePixels="True"/>
                                                    </Border>
                                                    <CheckBox Content="{Binding PreviewLabel}" IsChecked="{Binding IsSelected, Mode=TwoWay}" FontSize="11" Margin="0,2,0,0"
                                                              Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Details Panel for Selected Group -->
                <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}" Padding="16" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel>
                        <TextBlock Text="Group Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                        <ItemsControl ItemsSource="{Binding SelectedGroup.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Thumbnail}"
                                               MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding FileName}" Width="180"/>
                                        <TextBlock Text="{Binding FileType}" Width="60"/>
                                        <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0} bytes}" Width="100"/>
                                        <TextBlock Text="{Binding DateTaken, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,1,0,0" Padding="10,6">
                    <DockPanel LastChildFill="True">
                        <ProgressBar DockPanel.Dock="Left"
                                     Width="170"
                                     Height="16"
                                     Margin="0,0,10,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressPercent}" />

                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MenuForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ScanProgressMessage}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Theme.TextSecondary.Brush}"
                                       Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        <!-- Settings overlay: span all columns so it covers main content + sidebar -->
        <Grid x:Name="SettingsOverlay" Grid.ColumnSpan="3"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Visibility="{Binding ShowSettingsDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="995">
            <Border Background="{DynamicResource Theme.Hover.Brush}" MouseDown="CloseSettings_Click"/>
            
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="{DynamicResource MenuBackgroundBrush}" 
                    CornerRadius="15" Padding="25" Width="550"
                    BorderBrush="{DynamicResource MenuForegroundBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" 
                               Foreground="{DynamicResource MenuForegroundBrush}"/>
                    
                    <TextBlock Text="Save Destination" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DockPanel Margin="0,0,0,20">
                        <Button x:Name="SettingsBrowseBtn" Content="Browse" DockPanel.Dock="Right" 
                                Padding="10,5" Click="Browse_Click"/>
                        <TextBox x:Name="DestPathDisplay" IsReadOnly="True" Margin="0,0,10,0"
                                 Text="{Binding DestinationRoot, Mode=TwoWay}"/>
                    </DockPanel>
                    <Separator Margin="0,0,0,12"/>

                    <TextBlock Text="File Naming Scheme" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Preset" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding NamingPresetOptions}" SelectedItem="{Binding NamingPreset, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <WrapPanel Margin="0,0,0,6">
                        <CheckBox Content="Date" IsChecked="{Binding NamingIncludeDate, Mode=TwoWay}" Margin="0,0,16,0"/>
                        <CheckBox Content="Time" IsChecked="{Binding NamingIncludeTime, Mode=TwoWay}" Margin="0,0,16,0"/>
                        <CheckBox Content="Sequence" IsChecked="{Binding NamingIncludeSequence, Mode=TwoWay}" Margin="0,0,16,0"/>
                        <CheckBox Content="Shoot Name" IsChecked="{Binding NamingIncludeShootName, Mode=TwoWay}" Margin="0,0,16,0"/>
                        <CheckBox Content="Original Name" IsChecked="{Binding NamingIncludeOriginalName, Mode=TwoWay}"/>
                    </WrapPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="Date Format" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding NamingDateFormatOptions}" SelectedItem="{Binding NamingDateFormat, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="0">
                            <TextBlock Text="Time Format" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding NamingTimeFormatOptions}" SelectedItem="{Binding NamingTimeFormat, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Separator" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding NamingSeparatorOptions}" SelectedItem="{Binding NamingSeparator, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Shoot Name Sample" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NamingShootNameSample, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                    <CheckBox Content="Force lowercase output" IsChecked="{Binding NamingLowercase, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource MenuBackgroundBrush}"
                            BorderBrush="{DynamicResource MenuForegroundBrush}"
                            BorderThickness="1"
                            CornerRadius="5" Padding="10" Margin="0,4,0,20">
                        <StackPanel>
                            <TextBlock Text="Preview (examples)" FontWeight="SemiBold" Margin="0,0,0,6"
                                       Foreground="{DynamicResource MenuForegroundBrush}"/>
                            <ItemsControl ItemsSource="{Binding NamingPreviewExamples}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontWeight="Light"
                                                   Foreground="{DynamicResource MenuForegroundBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Separator Margin="0,0,0,12"/>
                    <TextBlock Text="Thumbnail Performance" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ThumbnailPerformanceOptions}" SelectedItem="{Binding ThumbnailPerformanceMode, Mode=TwoWay}" Margin="0,0,0,10"/>
                    <CheckBox Content="Expand stacked RAW/rendered previews side-by-side" IsChecked="{Binding ExpandPreviewStacks, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Duplicate Handling" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding DuplicatePolicyOptions}" SelectedItem="{Binding DuplicatePolicy, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <TextBlock Text="Verification Mode" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding VerificationModeOptions}" SelectedItem="{Binding VerificationMode, Mode=TwoWay}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Save Preset" Command="{Binding SavePresetCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"/>
                        <Button Content="Load Latest Preset" Command="{Binding LoadPresetCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>

                        <Button Content="Save &amp; Close" HorizontalAlignment="Right" 
                            Width="120" Click="CloseSettings_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>

