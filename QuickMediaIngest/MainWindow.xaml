                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource FilterFileTypeToDisplayConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerLastStyle}" ToolTip="{loc:Loc Toolbar_RebuildPreviewsTooltip}"><Button Command="{Binding ClearThumbnailCacheAndReloadPreviewsCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RebuildPreviewsTooltip}" Content="{loc:Loc Toolbar_RebuildPreviews}"/></Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                    <ItemsControl ItemsSource="{Binding ActiveFilterChips}" Margin="0,0,0,4">
