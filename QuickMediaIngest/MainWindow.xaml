<Window x:Class="QuickMediaIngest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuickMediaIngest"
    xmlns:models="clr-namespace:QuickMediaIngest.Core.Models"
    xmlns:loc="clr-namespace:QuickMediaIngest.Localization"
    xmlns:vm="clr-namespace:QuickMediaIngest.ViewModels"
    xmlns:converters="clr-namespace:QuickMediaIngest.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="{loc:Loc Main_WindowTitle}" Height="620" Width="960"
    Icon="QuickMediaIngest.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Background="{DynamicResource MaterialDesignPaper}"
    PreviewMouseWheel="Window_PreviewMouseWheel"
    PreviewKeyDown="Window_PreviewKeyDown"
    SizeChanged="Window_SizeChanged"
    StateChanged="Window_StateChanged"
    Closing="Window_Closing"
    Loaded="MainWindow_Loaded">
    <Window.InputBindings>
        <KeyBinding Key="I" Modifiers="Control" Command="{Binding ImportCommand}" />
        <KeyBinding Key="Q" Modifiers="Control" Command="{Binding QueueImportCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PreflightImportCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshAllSourcesCommand}" />
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="F1" Command="{Binding ShowShortcutsHelpCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:FilterFileTypeToDisplayConverter x:Key="FilterFileTypeToDisplayConverter" />

        <!-- Inverted Boolean to Boolean Converter for disabling during import -->
        <local:InvertBoolConverter x:Key="BoolToInvertedBoolConverter" />
        
        <!-- Text Converter for Import Button -->
        <local:BoolToImportingTextConverter x:Key="ImportingTextConverter" />
        <local:SourceToIconKindConverter x:Key="SourceToIconKindConverter" />

        <Style x:Key="FtpInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="SelectionBrush" Value="#FFE600"/>
            <Setter Property="SelectionOpacity" Value="0.95"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_SelectAll"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>
        </Style>

    </Window.Resources>

    <Grid>
        <TextBlock x:Name="LiveAnnouncementHost"
                   Width="1" Height="1" Margin="-99999,0,0,0"
                   Focusable="False"
                   IsHitTestVisible="False"
                   Visibility="Hidden"
                   Text="{Binding AccessibilityAnnouncement}" />
        <!-- Overlays (dialogs, notifications) -->
        <Grid x:Name="AddFtpOverlay" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowAddFtpDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900" Loaded="AddFtpOverlay_Loaded" Unloaded="AddFtpOverlay_Unloaded">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Ftp_AddSourceTitle}" Style="{StaticResource AppHeadingTextStyle}" FontSize="16" Margin="0,0,0,12"/>

                        <TextBlock Text="{loc:Loc Ftp_Host}" Style="{StaticResource AppBodyTextStyle}"/>
                        <TextBox Text="{Binding FtpHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <StackPanel Width="120">
                                <TextBlock Text="{loc:Loc Ftp_Port}" Style="{StaticResource AppBodyTextStyle}"/>
                                <TextBox Text="{Binding FtpPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="{loc:Loc Ftp_User}" Style="{StaticResource AppBodyTextStyle}"/>
                                <TextBox Text="{Binding FtpUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" Width="300" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{loc:Loc Ftp_Password}" Style="{StaticResource AppBodyTextStyle}" Margin="0,6,0,0"/>
                        <PasswordBox PasswordChar="●" PasswordChanged="PasswordBox_PasswordChanged"/>
                        <TextBlock Text="{loc:Loc Ftp_PasswordVaultHint}" Style="{StaticResource AppCaptionTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <TextBlock Text="{loc:Loc Ftp_RemoteFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,6,0,0"/>
                        <TextBox Text="{Binding FtpRemoteFolder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FtpInputTextBoxStyle}" />

                        <TextBlock Text="" Height="6"/>
                        <TextBlock Text="{Binding FtpDialogStatusMessage}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="{loc:Loc Btn_Test}" Command="{Binding TestFtpConnectionCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc Settings_Browse}" Command="{Binding BrowseFtpFoldersCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc Btn_Save}" Command="{Binding SaveFtpCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc Btn_Cancel}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowDriveSelectionDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="910">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc DriveSelect_Title}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,12"/>
                        <TextBlock Text="{loc:Loc DriveSelect_Description}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        <ListBox ItemsSource="{Binding DriveSelectionItems}" MaxHeight="280">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}" Style="{StaticResource AppBodyTextStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DriveType}" Style="{StaticResource AppCaptionTextStyle}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="{loc:Loc DriveSelect_SaveAndScan}" Command="{Binding ConfirmDriveSelectionCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc Btn_Cancel}" Command="{Binding CancelDriveSelectionCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- Settings overlay placeholder moved to end of root Grid (render on top) -->
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Border Width="760" Padding="18" CornerRadius="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding ScanDialogTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                    <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ScanProgressPercent}" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ScanProgressMessage}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{loc:Loc Scan_CurrentFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentScanFolder}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="{loc:Loc Scan_FilesFoundInFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentScanFolderTotalFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{loc:Loc Scan_FilesProcessedInFolder}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentScanFolderProcessedFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="{loc:Loc Scan_ScannedFolders}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ScannedFolders}" Style="{StaticResource AppBodyTextStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="{loc:Loc Scan_TotalFolders}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding TotalFoldersToScan}" Style="{StaticResource AppBodyTextStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="{loc:Loc Scan_ScannedFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ScannedFiles}" Style="{StaticResource AppBodyTextStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc Scan_TotalFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding TotalFilesToScan}" Style="{StaticResource AppBodyTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowImportProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Border Width="760" Padding="18" CornerRadius="8"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Import_InProgressTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                    <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{loc:Loc Import_OverallProgress}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding ProgressPercent}" Style="{StaticResource AppBodyTextStyle}"/>
                        <TextBlock Text="%" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Import_CurrentGroup}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentImportGroupTitle}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Import_FilesProcessed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="{Binding ProcessedFilesForImport}"/>
                                <TextBlock Text="/"/>
                                <TextBlock Text="{Binding TotalFilesForImport}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Import_Succeeded}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentFileBeingImported}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Import_Failed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FailedFilesForImport}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc Import_Elapsed}" FontWeight="SemiBold" Margin="0,0,10,6"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportElapsedText}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc Import_EtaSpeed}" FontWeight="SemiBold"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{loc:Loc About_Eta}"/>
                                <TextBlock Text="{Binding ImportEtaText}"/>
                                <TextBlock Text="  |  "/>
                                <TextBlock Text="{Binding ImportDataRateText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="{loc:Loc Import_CurrentGroupProgress}" Style="{StaticResource AppBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ProgressBar Height="12" Minimum="0" Maximum="100" Value="{Binding CurrentGroupProgressPercent}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Import_GroupFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentGroupFileBeingImported}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Import_GroupTotal}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding TotalFilesInCurrentGroup}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{loc:Loc Import_OverallTotalFiles}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding TotalFilesForImport}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Import_FailedInLastRun}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding FailedImportRecords.Count}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Import_QueuedJobs}" Style="{StaticResource AppBodyTextStyle}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding QueuedImportCount}" Style="{StaticResource AppBodyTextStyle}"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding FailedImportRecords}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" Style="{StaticResource AppCaptionTextStyle}" Foreground="{DynamicResource Theme.Error.Brush}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{loc:Loc Btn_CancelImport}"
                                Command="{Binding CancelActiveImportCommand}"
                                Visibility="{Binding IsImporting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource DialogOutlinedButtonStyle}"
                                Padding="14,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowSkippedFoldersDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="900">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="560" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding SkippedFoldersReportTitle}" Style="{StaticResource AppDialogTitleTextStyle}" Margin="0,0,0,10"/>
                        <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding SkippedFoldersReportText}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <CheckBox Margin="0,12,0,0"
                                  Visibility="{Binding ShowSkippedFoldersSuppressReminderOption, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Content="{loc:Loc SkippedFolders_DontRemindExcluded}"
                                  IsChecked="{Binding SuppressExcludedFolderScanReminders, Mode=TwoWay}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="{loc:Loc Btn_Copy}" Command="{Binding CopySkippedFoldersReportCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc Btn_Close}" Command="{Binding CloseSkippedFoldersReportCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- About dialog overlay (includes update checking) -->
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False" Background="Transparent" Visibility="{Binding ShowAboutDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="950">
            <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="14" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>
            <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="640" Padding="18" CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc About_Title}" Style="{StaticResource AppHeadingTextStyle}" Margin="0,0,0,12"/>
                        <TextBlock Text="{loc:Loc About_Description}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock Text="{loc:Loc About_Glossary}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{loc:Loc About_Glossary_TermPreflight}" FontWeight="SemiBold"/>
                            <TextBlock Text="{loc:Loc About_Glossary_DefPreflight}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBlock Text="{loc:Loc About_Glossary_TermUnified}" FontWeight="SemiBold"/>
                            <TextBlock Text="{loc:Loc About_Glossary_DefUnified}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBlock Text="{loc:Loc About_Glossary_TermShoot}" FontWeight="SemiBold"/>
                            <TextBlock Text="{loc:Loc About_Glossary_DefShoot}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="{loc:Loc About_Version}" FontWeight="SemiBold" Width="120"/>
                            <TextBlock Text="{Binding AppVersion}"/>
                        </StackPanel>

                        <Separator Margin="0,12,0,12" />

                        <TextBlock Text="{loc:Loc About_UpdateChecking}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc About_Package}" Width="120" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding PackageTypeOptions}" SelectedItem="{Binding UpdatePackageType}" Width="160" />
                            <TextBlock Text="{loc:Loc About_Interval}" Width="100" Margin="16,0,0,0" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding UpdateIntervalHours}" SelectedValuePath="Hours" DisplayMemberPath="Display" Width="160" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="{loc:Loc About_CheckUpdatesNow}" Command="{Binding RefreshUpdateCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{loc:Loc About_DownloadUpdate}" Command="{Binding DownloadUpdateCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="" Height="8"/>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                            <ProgressBar Minimum="0" Maximum="100" Height="14" Width="520" Value="{Binding UpdateProgress}" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ProgressBar IsIndeterminate="True" Height="14" Width="520" Visibility="{Binding IsCheckingForUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{loc:Loc About_Speed}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UpdateDownloadSpeedText}" Margin="0,0,12,0" />
                                <TextBlock Text="{loc:Loc About_Eta}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding UpdateDownloadEtaText}" />
                            </StackPanel>
                        </StackPanel>
                        <Separator Margin="0,12,0,12" />
                        <TextBlock Text="{loc:Loc About_Diagnostics}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="{loc:Loc About_OpenLogsFolder}" Click="OpenLogs_Click" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="{loc:Loc About_ReportBug}" Click="ReportBug_Click" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="{loc:Loc About_Changelog}" Command="{Binding OpenChangelogCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0" />
                            <Button Content="{loc:Loc About_Releases}" Command="{Binding OpenGitHubCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{loc:Loc About_Version}" FontWeight="SemiBold" Width="80"/>
                            <TextBlock Text="{Binding AppVersion}" Width="120"/>
                            <TextBlock Text="{loc:Loc About_BuildDate}" FontWeight="SemiBold" Width="80"/>
                            <TextBlock Text="{Binding BuildDate}" Width="120"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{loc:Loc Btn_Close}" Command="{Binding ToggleAboutCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- Import History: root-level overlay (same VisualBrush blur as Settings/About) -->
        <Grid Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False"
              Visibility="{Binding ShowImportHistoryDialog, Converter={StaticResource BooleanToVisibilityConverter}}"
              Panel.ZIndex="955">
            <Border Background="Transparent" MouseDown="CloseImportHistory_Click">
                <Grid>
                    <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <BlurEffect Radius="14" RenderingBias="Performance"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
                </Grid>
            </Border>
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource MaterialDesignPaper}"
                    CornerRadius="8" Padding="18" Width="720" MaxHeight="520"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{loc:Loc Btn_ImportHistory}" Style="{StaticResource AppHeadingTextStyle}" FontSize="18"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding ImportHistoryRecords}" Margin="0,8,0,8" MinHeight="280"
                              Background="{DynamicResource MaterialDesignPaper}"
                              BorderBrush="{DynamicResource MaterialDesignDivider}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{loc:Loc History_ColumnStarted}" Width="180" DisplayMemberBinding="{Binding StartedAtDisplay}"/>
                                <GridViewColumn Header="{loc:Loc History_ColumnSummary}" Width="420" DisplayMemberBinding="{Binding SummaryDisplay}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="90" Margin="6" Content="{loc:Loc History_Export}" Command="{Binding ExportImportHistoryCommand}" Style="{StaticResource DialogPrimaryButtonStyle}"/>
                        <Button Width="90" Margin="6" Content="{loc:Loc History_Clear}" Click="ImportHistory_Clear_Click" Style="{StaticResource DialogPrimaryButtonStyle}"/>
                        <Button Width="90" Margin="6" Content="{loc:Loc Btn_Close}" Command="{Binding CloseImportHistoryCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <!-- Main layout: Sidebar + Main Content -->
        <Grid x:Name="MainChromeRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="56" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid x:Name="SidebarHeaderGrid" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="SidebarTitlePanel" Grid.Column="0">
                            <Image x:Name="SidebarLogoCollapsed"
                                   Source="QuickMediaIngest.ico"
                                   Width="20"
                                   Height="20"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,4"/>
                            <TextBlock x:Name="SidebarAppNameText" Text="{loc:Loc Sidebar_AppName}" Style="{StaticResource SidebarTitleTextStyle}"/>
                            <TextBlock x:Name="SidebarAppVersionText" Text="{Binding AppVersion, StringFormat='v{0}'}" Style="{StaticResource AppMutedTextStyle}" Margin="0,4,0,0" />
                            <!-- Center column pins the collapse control when sidebar is narrow; code spans all columns when expanded -->
                            <Grid x:Name="SidebarCollapseToggleHostGrid" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="SidebarCollapseToggle" Grid.Column="0" Grid.ColumnSpan="3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Left"
                                              Style="{StaticResource SidebarRowToggleStyle}"
                                              IsChecked="{Binding SidebarCollapsed, Mode=TwoWay}"
                                              Checked="SidebarCollapseToggle_Toggled"
                                              Unchecked="SidebarCollapseToggle_Toggled"
                                              ToolTip="{loc:Loc Sidebar_CollapseTooltip}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="SidebarHeaderToggleIcon" Kind="DockLeft" Style="{StaticResource SidebarIconStyle}" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="SidebarHeaderLabelText" Text="{loc:Loc Sidebar_Label}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                            <Border x:Name="SidebarThemeHeaderBorder" Style="{StaticResource SidebarRowContainerStyle}" Margin="0,10,0,0">
                                <ToggleButton x:Name="ThemeToggle"
                                              Style="{StaticResource SidebarRowToggleStyle}"
                                              Checked="PillToggle_Toggled"
                                              Unchecked="PillToggle_Toggled"
                                              ToolTip="{loc:Loc Theme_Tooltip}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ThemeLightDark" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Theme_Label}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Expanded sidebar content -->
                    <Grid x:Name="SidebarExpandedContent" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <StackPanel x:Name="RibbonTilePanel" Orientation="Horizontal" AllowDrop="True" Margin="12,8,12,8" VerticalAlignment="Top"
                                        DragOver="RibbonTilePanel_DragOver" Drop="RibbonTilePanel_Drop" DragLeave="RibbonTilePanel_DragLeave" />
                            <StackPanel Orientation="Horizontal" Margin="16,8,16,2" HorizontalAlignment="Left">
                                <materialDesign:PackIcon Kind="FolderMultiple" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Sidebar_Sources}" Style="{StaticResource SidebarHeaderTextStyle}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" Margin="12,0,12,10"
                                     VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     MaxHeight="180">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <materialDesign:PackIcon Kind="{Binding Converter={StaticResource SourceToIconKindConverter}}" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                        <Expander Grid.Row="1" Margin="12,0,12,8" IsExpanded="{Binding SidebarNotificationsExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BellOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Sidebar_Notifications}" Style="{StaticResource SidebarHeaderTextStyle}" />
                                </StackPanel>
                            </Expander.Header>
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="{Binding DeleteAfterImportStatusLine}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.Warning.Brush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleteAfterImportEnabled}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedFilesStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DestinationStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding RawGroupingStatusText}" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
                                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRawJpegGroupingEnabled}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding KeywordsStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding PreviewHealthSummary}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding FtpThumbnailPhaseDetail}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding LastImportSummary}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <Separator Margin="0,8,0,8"/>
                                    <TextBlock Text="{loc:Loc Sidebar_NotificationFeed}" Style="{StaticResource SidebarHeaderTextStyle}" Margin="0,0,0,4"/>
                                    <Button Content="{loc:Loc Notify_ClearFeed}"
                                            Command="{Binding ClearNotificationFeedCommand}"
                                            Style="{StaticResource DialogOutlinedButtonStyle}"
                                            Padding="8,2" Margin="0,0,0,6"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding NotificationFeed}" Margin="0,4,0,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NotificationFeedLine}">
                                            <StackPanel Margin="0,2,0,2">
                                                <Separator Margin="0,4,0,6" Visibility="{Binding IsSessionDivider, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource AppCaptionTextStyle}">
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UseSuccessAccent}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Expander>
                    </Grid>

                    <!-- Collapsed icon rail -->
                    <StackPanel x:Name="SidebarCollapsedRail" Grid.Row="1" Visibility="Collapsed" Margin="8,12,8,8">
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Click="ThemeIconButton_Click" ToolTip="{loc:Loc Theme_Tooltip}" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <ItemsControl ItemsSource="{Binding Sources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarChromeIconButtonStyle}"
                                            Tag="{Binding}"
                                            Click="CollapsedSourceButton_Click"
                                            ToolTip="{Binding}"
                                            Margin="0,0,0,4">
                                        <materialDesign:PackIcon Kind="{Binding Converter={StaticResource SourceToIconKindConverter}}" Style="{StaticResource SidebarIconStyle}" Width="18" Height="18"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" ToolTip="{loc:Loc Sidebar_NotificationsIconTooltip}" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="BellOutline" Style="{StaticResource SidebarIconStyle}" Width="18" Height="18"/></Button>
                    </StackPanel>

                    <!-- Bottom Settings menu -->
                    <Expander x:Name="SettingsExpandedPanel" Grid.Row="2" Margin="8,8,8,12" IsExpanded="{Binding SettingsMenuExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Sidebar_SettingsHeader}" Style="{StaticResource SidebarSectionTitleTextStyle}" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleSettingsCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Tune" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_Preferences}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding OpenScanExclusionsCommand}"
                                        ToolTip="{loc:Loc Sidebar_ScanExclusionsTooltip}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="FolderRemoveOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Sidebar_ScanExclusions}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleAddFtpCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="LanConnect" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_AddFtpSource}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding OpenImportHistoryCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="History" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_ImportHistory}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleAboutCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="InformationOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_AboutUpdates}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                        </StackPanel>
                    </Expander>
                    <StackPanel x:Name="SettingsCollapsedRail" Grid.Row="2" Visibility="Collapsed" Margin="8,8,8,12">
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleSettingsCommand}" ToolTip="{loc:Loc Btn_Preferences}" Margin="0,0,0,4"><materialDesign:PackIcon Kind="Tune" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding OpenScanExclusionsCommand}" ToolTip="{loc:Loc Sidebar_ScanExclusionsTooltip}" Margin="0,0,0,4"><materialDesign:PackIcon Kind="FolderRemoveOutline" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleAddFtpCommand}" ToolTip="{loc:Loc Btn_AddFtpSource}" Margin="0,0,0,4"><materialDesign:PackIcon Kind="LanConnect" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding OpenImportHistoryCommand}" ToolTip="{loc:Loc Btn_ImportHistory}" Margin="0,0,0,4"><materialDesign:PackIcon Kind="History" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleAboutCommand}" ToolTip="{loc:Loc Btn_AboutUpdates}" Margin="0,0,0,4"><materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ExitApplicationCommand}" ToolTip="{loc:Loc Btn_Exit_Tooltip}" Margin="0,4,0,0"><materialDesign:PackIcon Kind="ExitToApp" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                    </StackPanel>

                    <!-- Exit: expanded sidebar only; collapsed rail uses icon-only Exit (IsChecked=true => sidebar collapsed) -->
                    <Border x:Name="SidebarExitFooterBorder" Grid.Row="3" Margin="8,4,8,12" Padding="0,8,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SidebarCollapseToggle, Path=IsChecked}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Style="{StaticResource SidebarRowButtonStyle}"
                                Command="{Binding ExitApplicationCommand}"
                                ToolTip="{loc:Loc Btn_Exit_Tooltip}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ExitToApp" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Btn_Exit}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Sidebar resizer -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Main Content -->
            <Grid Grid.Column="2" Background="{DynamicResource MaterialDesignPaper}" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top action and settings bands -->
                <Border Grid.Row="0"
                        Background="{DynamicResource MenuBackgroundBrush}"
                        BorderBrush="{DynamicResource MenuForegroundBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center" Margin="0,0,0,4">
                            <Border Style="{StaticResource TopBarSectionCardStyle}" ToolTip="{loc:Loc Toolbar_ImportActionsTooltip}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Toolbar_ImportActions}" Style="{StaticResource AppSubheadingTextStyle}" Margin="0,0,0,4"/>
                                    <WrapPanel Style="{StaticResource TopBarControlsWrapStyle}">
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ImportTooltip}"><Button Command="{Binding ImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_ImportTooltip}" Content="{loc:Loc Toolbar_Import}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_QueueTooltip}"><Button Command="{Binding QueueImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_QueueTooltip}" Content="{loc:Loc Toolbar_Queue}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_PreflightTooltip}"><Button Command="{Binding PreflightImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_PreflightTooltip}" Content="{loc:Loc Toolbar_Preflight}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_RetryFailedTooltip}"><Button Command="{Binding RetryFailedImportsCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RetryFailedTooltip}" Content="{loc:Loc Toolbar_RetryFailed}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ResumePendingTooltip}"><Button Command="{Binding ResumePendingImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_ResumePendingTooltip}" Content="{loc:Loc Toolbar_ResumePending}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_RefreshTooltip}"><Button Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RefreshTooltip}" Content="{loc:Loc Toolbar_Refresh}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerLastStyle}">
                                            <ToggleButton x:Name="DeleteAfterImportCheckBox"
                                                          Content="{loc:Loc Toolbar_DeleteAfterImport}"
                                                          Style="{StaticResource TopBarDangerToggleStyle}"
                                                          IsChecked="{Binding DeleteAfterImport, Mode=TwoWay}"
                                                          Checked="DeleteAfterImportCheckBox_Checked"
                                                          ToolTip="{loc:Loc Toolbar_DeleteAfterImportTooltip}"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TopBarSectionCardLastStyle}" ToolTip="{loc:Loc Toolbar_ViewSectionTooltip}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Toolbar_ViewSection}" Style="{StaticResource AppSubheadingTextStyle}" Margin="0,0,0,4"/>
                                    <WrapPanel Style="{StaticResource TopBarControlsWrapStyle}">
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_SelectAllTooltip}">
                                            <ToggleButton x:Name="SelectAllCheckBox" Style="{StaticResource TopBarActionToggleStyle}" Checked="SelectAllCheckBox_Checked" Unchecked="SelectAllCheckBox_Unchecked" ToolTip="{loc:Loc Toolbar_SelectAllTooltip}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CheckAll" Width="14" Height="14" Margin="0,0,6,0" Foreground="{DynamicResource MenuForegroundBrush}"/>
                                                    <TextBlock Text="{loc:Loc Toolbar_SelectAll}" Style="{StaticResource AppTextPrimaryStyle}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ExpandAllGroupsTooltip}">
                                            <ToggleButton Style="{StaticResource TopBarActionToggleStyle}" IsChecked="{Binding AllGroupsExpanded, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="14" Height="14" Margin="0,0,6,0" Foreground="{DynamicResource MenuForegroundBrush}"/>
                                                    <TextBlock Text="{loc:Loc Toolbar_ExpandAllGroups}" Style="{StaticResource AppTextPrimaryStyle}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_GroupByTooltip}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" Foreground="{DynamicResource MenuForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Slider x:Name="HourIntervalSlider" Minimum="1" Maximum="24" Width="110" Value="{Binding TimeBetweenShootsHours, Mode=TwoWay}" SmallChange="1" IsSnapToTickEnabled="True" ToolTip="{loc:Loc Toolbar_GroupByTooltip}"/>
                                                <Border Background="{DynamicResource MenuForegroundBrush}" CornerRadius="4" Margin="6,0,0,0" Padding="5,2">
                                                    <TextBlock Text="{Binding ElementName=HourIntervalSlider, Path=Value, StringFormat={}{0}h}" Foreground="{DynamicResource MenuBackgroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ThumbTooltip}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Magnify" Width="15" Height="15" Foreground="{DynamicResource MenuForegroundBrush}" Margin="0,0,6,0"/>
                                                <materialDesign:PackIcon Kind="Minus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                                                <Slider x:Name="ThumbnailZoomSlider" Minimum="50" Maximum="300" Width="120" Value="{Binding ThumbnailSize, Mode=TwoWay}" Margin="5,0" ToolTip="{loc:Loc Toolbar_ThumbTooltip}"/>
                                                <materialDesign:PackIcon Kind="Plus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_FilterTooltip}">
                                            <TextBox x:Name="FilterKeywordTextBox"
                                                     Width="150"
                                                     Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{loc:Loc Toolbar_FilterTooltip}"
                                                     Style="{StaticResource TopBarFieldTextBoxStyle}"
                                                     materialDesign:HintAssist.Hint="{loc:Loc Toolbar_FilterHint}"
                                                     materialDesign:HintAssist.IsFloating="False"/>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_FilterFileTypeTooltip}">
