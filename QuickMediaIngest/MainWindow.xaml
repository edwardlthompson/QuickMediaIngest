<Window x:Class="QuickMediaIngest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quick Media Ingest" Height="600" Width="900"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Sources -->
        <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Sources" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="16" FontWeight="Bold"/>
                
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <!-- Sidebar items will go here -->
                        <materialDesign:Card Margin="8" Padding="12">
                            <TextBlock Text="📷 SD Card (E:)" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </materialDesign:Card>
                        <materialDesign:Card Margin="8" Padding="12">
                            <TextBlock Text="📱 Phone (FTP)" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
                
                <Button Grid.Row="2" Content="Add FTP Source" Margin="16" Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Top Controls -->
            <StackPanel Orientation="Horizontal" Margin="16">
                <TextBox materialDesign:HintAssist.Hint="Album Name" Width="300" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Text="Vacation 2025"/>
                <Button Content="Import" Margin="16,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
            
            <!-- Thumbnail Grid -->
            <ScrollViewer Grid.Row="1" Margin="8">
                <ItemsControl>
                    <!-- Grid of thumbnails will populate here -->
                    <WrapPanel Orientation="Horizontal">
                        <materialDesign:Card Width="150" Height="150" Margin="8">
                            <Grid>
                                <TextBlock Text="Group 1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </materialDesign:Card>
                    </WrapPanel>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Status Bar -->
            <StatusBar Grid.Row="2" Background="{DynamicResource MaterialDesignDarkBackground}">
                <StatusBarItem>
                    <TextBlock Text="Ready" Foreground="White"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>
