                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="8,2,4,2" Margin="0,0,8,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Style="{StaticResource AppCaptionTextStyle}" Margin="4,0,4,0"/>
                                        <Button Content="✕" FontSize="11"
                                                AutomationProperties.Name="{loc:Loc A11y_RemoveFilterChip}"
                                                Command="{Binding DataContext.RemoveFilterChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource TopBarActionButtonStyle}"
                                                Padding="4,0" MinWidth="22" Height="22"
                                                ToolTip="{loc:Loc Toolbar_RemoveFilterTooltip}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- Grouped Import Items List -->
                <Grid Grid.Row="1" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0,0,0,14" Padding="14" CornerRadius="8"
                            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                            Background="{DynamicResource Theme.CardBackground.Brush}"
                            Visibility="{Binding ShowPostDeleteRecoveryBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Banner_PostDeleteRecovery}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="{loc:Loc Btn_OpenRecycleBin}" Command="{Binding OpenRecycleBinCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,10,0" Padding="14,8"/>
                                <Button Content="{loc:Loc Btn_Close}" Command="{Binding DismissPostDeleteRecoveryBannerCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Padding="14,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                <ListView ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" Name="GroupsListView" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False"
                          Visibility="{Binding ShowShootGroupsList, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12" HorizontalAlignment="Stretch" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="6" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{loc:Loc Menu_SkipFolderFuture}"
                                                  Command="{Binding DataContext.SkipFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding FolderPath}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" MinWidth="120" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.ToggleGroupExpandedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TopBarActionButtonStyle}"
                                                Width="34"
                                                Height="30"
                                                Margin="0,0,8,0"
                                                ToolTip="{loc:Loc Shoot_GroupExpandTooltip}">
                                            <Path Data="M 2 2 L 2 12 L 10 7 Z"
                                                  Fill="{DynamicResource MenuForegroundBrush}"
                                                  Width="12"
                                                  Height="14"
                                                  Stretch="Fill"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="90"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Button>
                                        <TextBox Grid.Column="1" Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontWeight="SemiBold" FontSize="14" BorderThickness="0,0,0,1" Margin="0,0,8,0"
                                                 GotKeyboardFocus="TextBox_SelectAll"
                                                 PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                                                 materialDesign:HintAssist.Hint="{loc:Loc Shoot_HintName}"
                                                 materialDesign:HintAssist.IsFloating="False"/>
                                        <Rectangle Grid.Column="2" Width="1" Margin="6,2,10,2" VerticalAlignment="Stretch"
                                                   Fill="{DynamicResource MaterialDesignDivider}" />
                                        <TextBox Grid.Column="3" Text="{Binding KeywordsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36" MaxHeight="96"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontSize="12"
                                                 materialDesign:HintAssist.Hint="{loc:Loc Shoot_HintKeywords}"
                                                 materialDesign:HintAssist.IsFloating="False"/>
                                        <StackPanel Grid.Column="4" Orientation="Vertical" Margin="4,0,10,0">
                                            <CheckBox Content="{loc:Loc Shoot_SelectShoot}" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top"/>
                                            <Button Content="{loc:Loc Shoot_ToggleStackLayout}"
                                                    Command="{Binding DataContext.ToggleShootStackExpandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource TopBarActionButtonStyle}"
                                                    FontSize="11"
                                                    Margin="0,6,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="4,0"
                                                    Visibility="{Binding DataContext.GroupRawAndRenderedPairs, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="{loc:Loc Shoot_ToggleStackTooltip}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="5">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_SourceFolderLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding FolderPath}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_StartLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding StartDate, StringFormat=yyyy-MM-dd HH:mm}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_EndLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding EndDate, StringFormat=yyyy-MM-dd HH:mm}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_FilesLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding Items.Count}"/>
                                            </StackPanel>
                                            <Button Content="{loc:Loc Shoot_IgnoreFolder}"
                                                    Command="{Binding DataContext.SkipFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding FolderPath}"
                                                    Style="{StaticResource DialogOutlinedButtonStyle}"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    ToolTip="{loc:Loc Shoot_IgnoreFolderTooltip}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Separator Margin="0,4,0,8" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding Items}" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,8,8" Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4" Padding="2">
                                                        <Grid MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="Uniform"
                                                                   SnapsToDevicePixels="True">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailPreviewStatus}" Value="{x:Static models:ThumbnailPreviewStatus.Failed}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Border Background="#66000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailPreviewStatus}" Value="{x:Static models:ThumbnailPreviewStatus.Failed}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <materialDesign:PackIcon Kind="ImageBroken" Width="28" Height="28" Foreground="#FFF5F5F5" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{loc:Loc Preview_Failed}" FontSize="10" Foreground="#FFF5F5F5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <CheckBox Content="{Binding PreviewLabel}" IsChecked="{Binding IsSelected, Mode=TwoWay}" FontSize="11" Margin="0,2,0,0"
                                                              Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Border Padding="28"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        Background="{DynamicResource Theme.CardBackground.Brush}"
                        Visibility="{Binding ShowShootListEmptyPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="440">
                        <StackPanel Visibility="{Binding ShowEmptyNoSourcesPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_NoSourcesTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" HorizontalAlignment="Left" Padding="16,8"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyFilterPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_FilterNoMatchTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="{loc:Loc Empty_ClearFilters}" Command="{Binding ClearFiltersCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" HorizontalAlignment="Left" Padding="16,8"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyFtpFailurePanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_FtpFailureTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <TextBlock Text="{loc:Loc Empty_FtpFailureBody}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{loc:Loc Toolbar_Refresh}" Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_Close}" Command="{Binding DismissFtpProblemHintsCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyScanPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_NoFilesTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{loc:Loc Toolbar_Refresh}" Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                    </Grid>
                </Grid>
                <!-- Details Panel for Selected Group -->
                <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}" Padding="16" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Details_GroupDetails}" Style="{StaticResource AppHeadingTextStyle}" Margin="0,0,0,8"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                        <ItemsControl ItemsSource="{Binding SelectedGroup.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Thumbnail}"
                                               MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding FileName}" Width="180"/>
                                        <TextBlock Text="{Binding FileType}" Width="60"/>
                                        <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0} bytes}" Width="100"/>
                                        <TextBlock Text="{Binding DateTaken, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,1,0,0" Padding="10,6">
                    <DockPanel LastChildFill="True">
                        <ProgressBar DockPanel.Dock="Left"
                                     Width="170"
                                     Height="16"
                                     Margin="0,0,10,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressPercent}" />

                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MenuForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ScanProgressMessage}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Theme.TextSecondary.Brush}"
                                       Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- Settings: root-level overlay so VisualBrush blur matches other modals (not a child of MainChromeRoot) -->
        <Grid x:Name="SettingsOverlay"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False"
              Visibility="{Binding ShowSettingsDialog, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1100">
            <Border Background="Transparent" MouseDown="CloseSettings_Click">
                <Grid>
                    <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <BlurEffect Radius="14" RenderingBias="Performance"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
                </Grid>
            </Border>
            
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource MenuBackgroundBrush}"
                    CornerRadius="15" Padding="25" Width="580"
                    Margin="16"
                    MaxHeight="{Binding ElementName=SettingsOverlay, Path=ActualHeight}"
                    BorderBrush="{DynamicResource MenuForegroundBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{loc:Loc Settings_MainTitle}" Style="{StaticResource AppHeadingLargeTextStyle}" Margin="0,0,0,16"
                               Foreground="{DynamicResource MenuForegroundBrush}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0">
                        <StackPanel>
                            <Expander IsExpanded="{Binding SettingsPrefsDestinationExpanded, Mode=TwoWay}" Margin="0,0,0,10" Foreground="{DynamicResource MenuForegroundBrush}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Loc Settings_SaveDestination}" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{loc:Loc Settings_DestinationPreset}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DestinationPresetOptions}"
                                              SelectedValue="{Binding DestinationPreset}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Label"
                                              Margin="0,0,0,12"/>
                                    <DockPanel Margin="0,0,0,4">
                                        <Button x:Name="SettingsBrowseBtn" Content="{loc:Loc Settings_Browse}" DockPanel.Dock="Right"
                                                Padding="10,5" Click="Browse_Click"
                                                Style="{StaticResource DialogOutlinedButtonStyle}"/>
                                        <TextBox x:Name="DestPathDisplay" IsReadOnly="True" Margin="0,0,10,0"
                                                 Text="{Binding DestinationRoot, Mode=TwoWay}"/>
                                    </DockPanel>
                                </StackPanel>
                            </Expander>

                            <Expander IsExpanded="{Binding SettingsPrefsNamingExpanded, Mode=TwoWay}" Margin="0,0,0,10" Foreground="{DynamicResource MenuForegroundBrush}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Loc Settings_FileNamingScheme}" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{loc:Loc Settings_Preset}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding NamingPresetOptions}" SelectedItem="{Binding NamingPreset, Mode=TwoWay}" Margin="0,0,0,10"/>

                                    <WrapPanel Margin="0,0,0,6">
                                        <CheckBox Content="{loc:Loc Settings_Date}" IsChecked="{Binding NamingIncludeDate, Mode=TwoWay}" Margin="0,0,16,0"/>
                                        <CheckBox Content="{loc:Loc Settings_Time}" IsChecked="{Binding NamingIncludeTime, Mode=TwoWay}" Margin="0,0,16,0"/>
                                        <CheckBox Content="{loc:Loc Settings_Sequence}" IsChecked="{Binding NamingIncludeSequence, Mode=TwoWay}" Margin="0,0,16,0"/>
                                        <CheckBox Content="{loc:Loc Settings_ShootName}" IsChecked="{Binding NamingIncludeShootName, Mode=TwoWay}" Margin="0,0,16,0"/>
                                        <CheckBox Content="{loc:Loc Settings_OriginalName}" IsChecked="{Binding NamingIncludeOriginalName, Mode=TwoWay}"/>
                                    </WrapPanel>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Grid.Row="0">
                                            <TextBlock Text="{loc:Loc Settings_DateFormat}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding NamingDateFormatOptions}" SelectedItem="{Binding NamingDateFormat, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Grid.Row="0">
                                            <TextBlock Text="{loc:Loc Settings_TimeFormat}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding NamingTimeFormatOptions}" SelectedItem="{Binding NamingTimeFormat, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="2">
                                            <TextBlock Text="{loc:Loc Settings_Separator}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <ComboBox ItemsSource="{Binding NamingSeparatorOptions}" SelectedItem="{Binding NamingSeparator, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{loc:Loc Settings_ShootNameSample}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding NamingShootNameSample, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_ForceLowercase}" IsChecked="{Binding NamingLowercase, Mode=TwoWay}" Margin="0,0,0,10"/>

                                    <Border Background="{DynamicResource MenuBackgroundBrush}"
                                            BorderBrush="{DynamicResource MenuForegroundBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5" Padding="10" Margin="0,4,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Loc Settings_PreviewExamples}" FontWeight="SemiBold" Margin="0,0,0,6"
                                                       Foreground="{DynamicResource MenuForegroundBrush}"/>
                                            <ItemsControl ItemsSource="{Binding NamingPreviewExamples}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontWeight="Light"
                                                                   Foreground="{DynamicResource MenuForegroundBrush}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <Expander IsExpanded="{Binding SettingsPrefsLanguageExpanded, Mode=TwoWay}" Margin="0,0,0,10" Foreground="{DynamicResource MenuForegroundBrush}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Loc Settings_Section_Language}" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{loc:Loc Settings_DisplayLanguage}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding UiLanguageOptions}"
                                              SelectedValue="{Binding UiLanguage, Mode=TwoWay}"
                                              SelectedValuePath="Code"
                                              DisplayMemberPath="Label"
                                              Margin="0,0,0,8"/>
                                    <TextBlock Text="{loc:Loc Settings_LanguageRestartHint}" Style="{StaticResource AppCaptionTextStyle}" TextWrapping="Wrap" Opacity="0.82"/>
                                </StackPanel>
                            </Expander>

                            <Expander IsExpanded="{Binding SettingsPrefsImportSettingsExpanded, Mode=TwoWay}" Margin="0,0,0,4" Foreground="{DynamicResource MenuForegroundBrush}">
                                <Expander.Header>
                                    <TextBlock Text="{loc:Loc Settings_Section_ImportSettings}" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <CheckBox Content="{loc:Loc Settings_EmbedKeywords}" IsChecked="{Binding EmbedKeywordsOnImport, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_ConfirmImport}" IsChecked="{Binding ConfirmBeforeImport, Mode=TwoWay}" Margin="0,0,0,14"/>

                                    <TextBlock Text="{loc:Loc Settings_ImportBehaviorSection}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_OpenDestinationWhenDone}" IsChecked="{Binding OpenDestinationFolderWhenImportCompletes, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_ShowDiskSpaceSummary}" IsChecked="{Binding ShowCompactImportSummaryModal, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_ConfirmCancelImport}" IsChecked="{Binding ConfirmCancelImportRequest, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <CheckBox Content="{loc:Loc Settings_SingleThreadImport}" IsChecked="{Binding ImportSingleThreaded, Mode=TwoWay}" Margin="0,0,0,8"/>
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock DockPanel.Dock="Left" Width="260" TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Text="{loc:Loc Settings_FileCooldownMs}" Margin="0,0,12,0"/>
                                        <TextBox Text="{Binding ImportCooldownBetweenFilesMs, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    </DockPanel>
                                    <Button Content="{loc:Loc Settings_OpenImportReportsFolder}" HorizontalAlignment="Left"
                                            Command="{Binding OpenImportReportsFolderCommand}"
                                            Style="{StaticResource DialogOutlinedButtonStyle}"
                                            Margin="0,0,0,16"/>

                                    <TextBlock Text="{loc:Loc Settings_ImportSubsection_Previews}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="{loc:Loc Settings_ThumbnailPerformance}" FontWeight="SemiBold" Margin="0,4,0,4"/>
                                    <ComboBox ItemsSource="{Binding ThumbnailPerformanceOptions}" SelectedItem="{Binding ThumbnailPerformanceMode, Mode=TwoWay}" Margin="0,0,0,10"/>
                                    <CheckBox Content="{loc:Loc Settings_GroupRawRendered}"
                                              IsChecked="{Binding GroupRawAndRenderedPairs, Mode=TwoWay}"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Content="{loc:Loc Settings_ExpandStacked}"
                                              IsChecked="{Binding ExpandPreviewStacks, Mode=TwoWay}"
                                              IsEnabled="{Binding GroupRawAndRenderedPairs}"
                                              Margin="0,0,0,14"/>

                                    <TextBlock Text="{loc:Loc Settings_DuplicateHandling}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DuplicatePolicyOptions}" SelectedItem="{Binding DuplicatePolicy, Mode=TwoWay}" Margin="0,0,0,10"/>

                                    <TextBlock Text="{loc:Loc Settings_VerificationMode}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding VerificationModeOptions}" SelectedItem="{Binding VerificationMode, Mode=TwoWay}" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="{loc:Loc Settings_SavePreset}" Command="{Binding SavePresetCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Content="{loc:Loc Settings_LoadLatestPreset}" Command="{Binding LoadPresetCommand}" Style="{StaticResource DialogOutlinedButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <Separator Margin="0,0,0,16"/>
                        <Button Content="{loc:Loc Settings_SaveClose}" HorizontalAlignment="Right"
                                Width="120" Click="CloseSettings_Click" IsDefault="True"
                                Style="{StaticResource DialogPrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Scan exclusions: root-level overlay (same blur as other modals) -->
        <Grid x:Name="ScanExclusionsOverlay"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False"
              Visibility="{Binding ShowScanExclusionsPanel, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1101">
            <Border Background="Transparent" MouseDown="CloseScanExclusions_Click">
                <Grid>
                    <Rectangle Margin="-10" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <VisualBrush Visual="{Binding ElementName=MainChromeRoot}" Stretch="Fill"/>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <BlurEffect Radius="14" RenderingBias="Performance"/>
                        </Rectangle.Effect>
                    </Rectangle>
                    <Border Margin="-10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#35303030" IsHitTestVisible="False"/>
                </Grid>
            </Border>
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource MenuBackgroundBrush}"
                    CornerRadius="15" Padding="22" Width="560" MaxHeight="640"
                    BorderBrush="{DynamicResource MenuForegroundBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{loc:Loc ScanExclusions_Title}" Style="{StaticResource AppHeadingLargeTextStyle}"
                                   Foreground="{DynamicResource MenuForegroundBrush}"/>
                        <TextBlock Text="{loc:Loc ScanExclusions_Subtitle}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="480">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc ScanExclusions_DrivesHeading}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Loc ScanExclusions_DrivesHint}" Style="{StaticResource AppCaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding ExcludedDriveEntries}" MaxHeight="140" Margin="0,0,0,16">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,2">
                                            <Button DockPanel.Dock="Right"
                                                    Content="{loc:Loc ScanExclusions_IncludeDrive}"
                                                    Style="{StaticResource DialogOutlinedButtonStyle}"
                                                    Command="{Binding DataContext.RemoveDriveExclusionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding DeviceId}"
                                                    Padding="8,2"
                                                    Margin="6,0,0,0"/>
                                            <TextBlock Text="{Binding Display}" Style="{StaticResource AppBodyTextStyle}" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="{loc:Loc ScanExclusions_FoldersHeading}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Loc ScanExclusions_FoldersHint}" Style="{StaticResource AppCaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding SkippedFolderRuleEntries}" MaxHeight="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,2">
                                            <Button DockPanel.Dock="Right"
                                                    Content="{loc:Loc ScanExclusions_RemoveFolder}"
                                                    Style="{StaticResource DialogOutlinedButtonStyle}"
                                                    Command="{Binding DataContext.RemoveSkippedFolderRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,2"
                                                    Margin="6,0,0,0"/>
                                            <TextBlock Text="{Binding Display}" Style="{StaticResource AppBodyTextStyle}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="{loc:Loc Btn_Close}" HorizontalAlignment="Right" Margin="0,16,0,0"
                            Width="120" Click="CloseScanExclusions_Click"
                            Style="{StaticResource DialogPrimaryButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

