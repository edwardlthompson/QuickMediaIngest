<Window x:Class="QuickMediaIngest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuickMediaIngest"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Quick Media Ingest" Height="620" Width="960"
    Icon="QuickMediaIngest.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Background="{DynamicResource MaterialDesignPaper}"
    PreviewMouseWheel="Window_PreviewMouseWheel"
    SizeChanged="Window_SizeChanged"
    StateChanged="Window_StateChanged">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Inverted Boolean to Boolean Converter for disabling during import -->
        <local:InvertBoolConverter x:Key="BoolToInvertedBoolConverter" />
        
        <!-- Text Converter for Import Button -->
        <local:BoolToImportingTextConverter x:Key="ImportingTextConverter" />

        <Style x:Key="FtpInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="SelectionBrush" Value="#FFE600"/>
            <Setter Property="SelectionOpacity" Value="0.95"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_SelectAll"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>
        </Style>

        <Style x:Key="ShootTitleTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="Yellow"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SelectionBrush" Value="#2A5FFF"/>
            <Setter Property="SelectionOpacity" Value="0.88"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_SelectAll"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>
        </Style>

        <Style x:Key="RibbonBandStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,5,12,5"/>
        </Style>



        <Style x:Key="RibbonSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="RibbonTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#16000000"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="RibbonTileHandleStyle" TargetType="Border">
            <Setter Property="Cursor" Value="SizeAll"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>


    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Sources -->
        <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sources" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="16,12,8,12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Margin="0,12,16,12" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Rescan Drives" Command="{Binding RescanCommand}" VerticalAlignment="Center" Padding="0">
                            <materialDesign:PackIcon Kind="Refresh" Height="20" Width="20" Foreground="{DynamicResource AppAccentBrush}"/>
                        </Button>
                    </Grid>
                </Grid>

                <ListBox Grid.Row="1" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" BorderThickness="0" Background="Transparent" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="4" Padding="12" materialDesign:ElevationAssist.Elevation="Dp1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Sd" VerticalAlignment="Center" Margin="0,0,8,0" Height="20" Width="20"/>
                                    <TextBlock Text="{Binding}" Style="{StaticResource MaterialDesignBody1TextBlock}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="12,12,12,12">
                    <Button Content="Add FTP Source" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource RibbonSidebarButtonStyle}" Margin="0,0,0,8" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                    <Button Content="Settings &amp; About" Command="{Binding ToggleAboutCommand}" Style="{StaticResource RibbonSidebarButtonStyle}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Loaded="MainContent_Loaded">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Theme Bar -->
                <RowDefinition Height="Auto"/> <!-- Notification Area -->
                <RowDefinition Height="Auto"/> <!-- Top Controls Banner -->
                <RowDefinition Height="*"/>    <!-- Thumbnail Grid -->
                <RowDefinition Height="Auto"/> <!-- Lower Status Bar -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="16,10,16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="TableLarge" Width="18" Height="18" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="Quick Media Ingest" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="WhiteBalanceSunny" Width="18" Height="18" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <ToggleButton Width="46" Height="24" Margin="0,0,8,0" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                        <materialDesign:PackIcon Kind="WeatherNight" Width="18" Height="18" Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Notification Area (Update Banner OR Success Notification) -->
            <StackPanel Grid.Row="1">
                <!-- Update Banner -->
                <Border Background="Yellow" Padding="6" CornerRadius="4" Margin="16,16,16,8" Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Update" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Black"/>
                        <TextBlock Text="A new version is available!" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        <Button Content="Download" Margin="16,0,0,0" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding DownloadUpdateCommand}" Padding="8,2" Height="24" Background="Black" Foreground="Yellow" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Success Notification Toast -->
                <Border Background="#4CAF50" Padding="6" CornerRadius="4" Margin="16,16,16,8" Visibility="{Binding ShowSuccessNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="CheckCircle" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                        <TextBlock Text="Import successful! Files have been added to your destination folder." VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Top Controls Banner -->
            <Border Grid.Row="2" Margin="0,0,0,8" Style="{StaticResource RibbonBandStyle}">
                <StackPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" CanContentScroll="False">
                        <StackPanel x:Name="RibbonTilePanel" Orientation="Horizontal" VerticalAlignment="Center" AllowDrop="True" Background="Transparent" DragOver="RibbonTilePanel_DragOver" Drop="RibbonTilePanel_Drop" DragLeave="RibbonTilePanel_DragLeave">

                            <!-- Import -->
                            <Border Tag="Import" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="FolderDownload" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <Button Grid.Column="1" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding ImportCommand}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}">
                                        <TextBlock Text="{Binding IsImporting, StringFormat={}, Converter={StaticResource ImportingTextConverter}}" TextWrapping="NoWrap"/>
                                    </Button>
                                    <Border Grid.Column="2" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Delete After Import -->
                            <Border Tag="DeleteAfterImport" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="Delete" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <CheckBox Grid.Column="1" Content="Delete After Import" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" IsChecked="{Binding DeleteAfterImport}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                                    <Border Grid.Column="2" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Select All -->
                            <Border Tag="SelectAll" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="CheckboxMultipleMarked" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <CheckBox Grid.Column="1" Content="Select All" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" IsChecked="{Binding SelectAll}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                                    <Border Grid.Column="2" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Include Subfolders -->
                            <Border Tag="IncludeSubfolders" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="FolderMultiple" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <CheckBox Grid.Column="1" Content="Include Subfolders" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" IsChecked="{Binding ScanIncludeSubfolders}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                                    <Border Grid.Column="2" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Hours Between Shoots -->
                            <Border Tag="HoursBetweenShoots" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="Clock" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Hours Between Shoots" TextWrapping="NoWrap" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" FontSize="13" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding TimeBetweenShootsHours, UpdateSourceTrigger=PropertyChanged}" Width="44" VerticalAlignment="Center" FontSize="13" Style="{StaticResource MaterialDesignOutlinedTextBox}" IsEnabled="{Binding IsImporting, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                                    <Border Grid.Column="3" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Zoom -->
                            <Border Tag="Zoom" Style="{StaticResource RibbonTileStyle}" AllowDrop="True">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="MagnifyPlus" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <Slider Grid.Column="1" Minimum="80" Maximum="250" Value="{Binding ThumbnailSize}" Width="100" VerticalAlignment="Center" Style="{StaticResource MaterialDesignSlider}" TickPlacement="None" AutoToolTipPlacement="None"/>
                                    <Border Grid.Column="2" Style="{StaticResource RibbonTileHandleStyle}" PreviewMouseLeftButtonDown="RibbonTileHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="RibbonTileHandle_PreviewMouseMove">
                                        <materialDesign:PackIcon Kind="DragVertical" Width="28" Height="28" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Thumbnail Grid -->
            <ScrollViewer Grid.Row="3" Margin="8">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="8" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" IsExpanded="False">
                                <Expander.Header>
                                    <Grid Width="Auto">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Bulk Checkbox -->
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Yellow"/>
                                        
                                        <!-- Editable Title -->
                                        <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShootTitleTextBoxStyle}"/>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                                            <TextBlock Text="📁 " />
                                            <TextBlock Text="{Binding FolderPath}" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <materialDesign:PackIcon Kind="ImageMultiple" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Items.Count}" FontWeight="Bold"/>
                                            <TextBlock Text=" items" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <Expander.Content>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Margin="8" Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}" Padding="4">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                        <materialDesign:PackIcon Kind="Video" Visibility="{Binding IsVideo, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#AA000000" Foreground="White" Width="20" Height="20" Margin="4"/>

                                                        <!-- Footer Location for Checkbox and Label beneath image frame -->
                                                        <Grid Grid.Row="1" Margin="2,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="Yellow"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Grid>
                                                </materialDesign:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="4" Style="{StaticResource RibbonBandStyle}" Padding="12,8" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Progress" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Width="140" Height="10" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryLightMidBrush}"/>
                        <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}" Foreground="{DynamicResource MaterialDesignBody}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{DynamicResource MaterialDesignBody}" Margin="16,0,4,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
            </Grid>
        <!-- Options Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#DD000000" Visibility="{Binding ShowAboutDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="7.6*"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Column="1" Grid.Row="1" MinWidth="460" MinHeight="520" MaxWidth="980" MaxHeight="900" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="16" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Settings &amp; Options" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,12"/>
                    
                    <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}">
                        
                        <!-- Tab 1: Import Settings -->
                        <TabItem Header="Import">
                            <StackPanel Margin="8">
                                <TextBlock Text="Import Location" FontWeight="Bold" Margin="0,0,0,4" FontSize="13" Foreground="{DynamicResource MaterialDesignBody}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding DestinationRoot}" IsEnabled="False" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="8" materialDesign:HintAssist.Hint="Select Folder"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseDestinationCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Text="File Naming Template" FontWeight="Bold" Margin="0,0,0,4" FontSize="13" Foreground="{DynamicResource MaterialDesignBody}"/>
                                                                 <TextBlock Text="Available Tokens (Drag to below target panel)" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,2"/>
                                 <ItemsControl ItemsSource="{Binding AvailableTokens}" Margin="0,0,0,8">
                                     <ItemsControl.ItemsPanel>
                                         <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                     </ItemsControl.ItemsPanel>
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <materialDesign:Chip Content="{Binding}" Margin="2" Padding="4" IsDeletable="False" Cursor="Hand" PreviewMouseLeftButtonDown="Token_PreviewMouseLeftButtonDown" PreviewMouseMove="Token_PreviewMouseMove"/>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>

                                 <TextBlock Text="Selected Format Design" FontSize="12" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,4,0,4" FontWeight="Bold"/>
                                 <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" Padding="6" Background="#11FFFFFF" CornerRadius="4" AllowDrop="True" Drop="Token_Drop" DragOver="Token_DragOver" MinHeight="40">
                                     <ItemsControl x:Name="SelectedTokensItemsControl" ItemsSource="{Binding SelectedTokens}">
                                         <ItemsControl.ItemsPanel>
                                             <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                         </ItemsControl.ItemsPanel>
                                         <ItemsControl.ItemTemplate>
                                             <DataTemplate>
                                                 <materialDesign:Chip Content="{Binding Value}" Margin="2" Padding="4" IsDeletable="True" DeleteClick="Token_DeleteClick" Cursor="Hand" PreviewMouseLeftButtonDown="Token_PreviewMouseLeftButtonDown" PreviewMouseMove="Token_PreviewMouseMove"/>
                                             </DataTemplate>
                                         </ItemsControl.ItemTemplate>
                                     </ItemsControl>
                                 </Border>
                                 <Border Margin="0,8,0,0" Padding="8" CornerRadius="4" Background="Yellow" BorderBrush="#333333" BorderThickness="1">
                                     <TextBlock Text="{Binding NamingTemplate, StringFormat='Example Filename Pattern: {0}'}" FontSize="14" FontWeight="Bold" Foreground="Black" TextWrapping="Wrap"/>
                                 </Border>

                                 <TextBlock Text="Recent Import History (latest 50)" FontWeight="Bold" Margin="0,16,0,6" FontSize="13" Foreground="{DynamicResource MaterialDesignBody}"/>
                                 <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4" Padding="6" Background="#11000000">
                                     <ListBox ItemsSource="{Binding ImportHistoryRecords}" MinHeight="120" MaxHeight="220" Background="Transparent" BorderThickness="0">
                                         <ListBox.ItemTemplate>
                                             <DataTemplate>
                                                 <TextBlock Text="{Binding SummaryDisplay}" Foreground="{DynamicResource MaterialDesignBody}" FontSize="11" TextWrapping="Wrap" Margin="0,2"/>
                                             </DataTemplate>
                                         </ListBox.ItemTemplate>
                                     </ListBox>
                                 </Border>
                            </StackPanel>
                        </TabItem>

                        <!-- Tab 2: About & Updates -->
                        <TabItem Header="About">
                            <StackPanel Margin="8,12,8,8">
                                <TextBlock Text="Quick Media Ingest" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource MaterialDesignBody}" TextAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding AppVersion, StringFormat='{}Version: {0}'}" Style="{StaticResource MaterialDesignBody2TextBlock}" TextAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Speedy ingestion pipeline manager." TextAlignment="Center" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,16"/>
                                <Button Content="Visit GitHub" Command="{Binding OpenGitHubCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Margin="0,0,0,16"/>

                                <Border Background="Yellow"
                                        Padding="8"
                                        CornerRadius="4"
                                        Margin="0,0,0,16"
                                        Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Update" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Black"/>
                                        <TextBlock Text="A new version is available!" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                                        <Button Content="Download"
                                                Margin="16,0,0,0"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Command="{Binding DownloadUpdateCommand}"
                                                Padding="8,2"
                                                Height="24"
                                                Background="Black"
                                                Foreground="Yellow"
                                                FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Update Checking" FontWeight="Bold" Margin="0,0,0,8" FontSize="13" Foreground="{DynamicResource MaterialDesignBody}" TextAlignment="Center" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                                    <TextBlock Text="Package:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding PackageTypeOptions}" SelectedItem="{Binding UpdatePackageType}" Width="120" Style="{StaticResource MaterialDesignComboBox}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Center">
                                    <TextBlock Text="Interval:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding UpdateIntervalHours}" SelectedValuePath="Hours" DisplayMemberPath="Display" Width="120" Style="{StaticResource MaterialDesignComboBox}"/>
                                </StackPanel>
                                <Button Content="Check for Updates Now" Command="{Binding RefreshUpdateCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                                        <Button Grid.Row="2" Content="Close" Command="{Binding ToggleAboutCommand}" HorizontalAlignment="Center" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,12,0,0"/>
                </Grid>
                                    </materialDesign:Card>
                                </Grid>
        </Grid>
        
        <!-- Add FTP Source Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#DD000000" Visibility="{Binding ShowAddFtpDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="5*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1.5*"/>
                                        <RowDefinition Height="7*"/>
                                        <RowDefinition Height="1.5*"/>
                                    </Grid.RowDefinitions>

                                    <materialDesign:Card Grid.Column="1" Grid.Row="1" MinWidth="350" MinHeight="420" MaxWidth="760" MaxHeight="860" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="16" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Add FTP Source" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="Yellow" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding FtpDialogStatusMessage}" Grid.Row="0" Margin="0,40,0,0" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Foreground="LightGray"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsFtpBusy, Converter={StaticResource BoolToInvertedBoolConverter}}">
                        <StackPanel Margin="4">
                            <TextBlock Text="Host / IP" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding FtpHost}" Style="{StaticResource FtpInputTextBoxStyle}"/>
                            
                            <TextBlock Text="Port" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding FtpPort}" Style="{StaticResource FtpInputTextBoxStyle}"/>
                            
                            <TextBlock Text="Username" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding FtpUser}" Style="{StaticResource FtpInputTextBoxStyle}"/>
                            
                            <TextBlock Text="Password" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding FtpPass}" Style="{StaticResource FtpInputTextBoxStyle}"/>
                            
                            <TextBlock Text="Remote Folder (e.g., /)" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding FtpRemoteFolder}" Style="{StaticResource FtpInputTextBoxStyle}" Margin="0,2,0,12"/>

                            <TextBlock Text="Common Android Folders" FontSize="11" Foreground="Gray"/>
                            <ComboBox ItemsSource="{Binding CommonFtpFolders}" SelectedItem="{Binding SelectedFtpPresetFolder}" Style="{StaticResource MaterialDesignComboBox}" Margin="0,2,0,12"/>

                            <TextBlock Text="FTP thumbnails now load automatically during scan with no batch limit." TextWrapping="Wrap" FontSize="11" Foreground="LightGray" Margin="0,0,0,12"/>

                            <Border Padding="10" Margin="0,0,0,12" CornerRadius="4" Background="#11FFFFFF" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Browse FTP folders before saving" FontSize="12" FontWeight="Bold" Foreground="Yellow" Margin="0,0,0,4"/>
                                    <TextBlock Text="Use this to confirm the phone path. Start with /DCIM or /DCIM/Camera for the fastest scan." TextWrapping="Wrap" FontSize="11" Foreground="LightGray" Margin="0,0,0,8"/>
                                    <ListBox ItemsSource="{Binding BrowsedFtpFolders}" SelectedItem="{Binding SelectedBrowsedFtpFolder}" DisplayMemberPath="Label" MinHeight="120" MaxHeight="180" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Browse Folders" Command="{Binding BrowseFtpFoldersCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" IsEnabled="{Binding IsBrowsingFtpFolders, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                                        <Button Content="Use Selected Folder" Command="{Binding UseBrowsedFtpFolderCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="Yellow"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button Content="Test Connection" Command="{Binding TestFtpConnectionCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="Yellow" Margin="0,0,8,0" Width="130" IsEnabled="{Binding IsFtpBusy, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                        <Button Content="Save" Command="{Binding SaveFtpCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0" Width="100" IsEnabled="{Binding IsFtpBusy, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                        <Button Content="Cancel" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Width="100" IsEnabled="{Binding IsFtpBusy, Converter={StaticResource BoolToInvertedBoolConverter}}"/>
                    </StackPanel>

                    <Border Grid.RowSpan="3" Background="#B0000000" CornerRadius="8" Visibility="{Binding IsFtpBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                            <TextBlock Text="Working With Phone FTP..." TextAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="Yellow" Margin="0,0,0,12"/>
                            <ProgressBar IsIndeterminate="True" Height="10" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryMidBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding FtpDialogStatusMessage}" TextAlignment="Center" TextWrapping="Wrap" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Scan Progress Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#AA000000" Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Column="1" Grid.Row="1" MinWidth="400" MaxWidth="620" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <StackPanel>
                        <TextBlock Text="{Binding ScanDialogTitle}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="Yellow" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ScannedFolders}" FontSize="28" FontWeight="Bold" Foreground="Yellow"/>
                            <TextBlock Text=" / " FontSize="28" FontWeight="Bold" Foreground="Gray" Margin="8,0"/>
                            <TextBlock Text="{Binding TotalFoldersToScan}" FontSize="28" FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text=" folders" FontSize="14" Foreground="Gray" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ScannedFiles}" FontSize="20" FontWeight="Bold" Foreground="Yellow"/>
                            <TextBlock Text=" / " FontSize="20" FontWeight="Bold" Foreground="Gray" Margin="6,0"/>
                            <TextBlock Text="{Binding TotalFilesToScan}" FontSize="20" FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text=" files" FontSize="12" Foreground="Gray" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
                        </StackPanel>

                        <ProgressBar Value="{Binding ScanProgressPercent}" Height="14" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryMidBrush}" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding ScanProgressPercent, StringFormat='Scan Progress: {0}%'}" FontSize="12" TextAlignment="Center" Foreground="Gray" Margin="0,0,0,14"/>
                        <TextBlock Text="{Binding ScanProgressMessage}" FontSize="12" TextAlignment="Center" Foreground="LightGray" TextWrapping="Wrap" MinHeight="32"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Import Progress Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#AA000000" Visibility="{Binding ShowImportProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Column="1" Grid.Row="1" MinWidth="400" MaxWidth="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <StackPanel>
                        <TextBlock Text="Importing Files..." Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="Yellow" Margin="0,0,0,20"/>
                        
                        <!-- File Count Display -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CurrentFileBeingImported}" FontSize="28" FontWeight="Bold" Foreground="Yellow"/>
                            <TextBlock Text=" / " FontSize="28" FontWeight="Bold" Foreground="Gray" Margin="8,0"/>
                            <TextBlock Text="{Binding TotalFilesForImport}" FontSize="28" FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text=" imported" FontSize="14" Foreground="Gray" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                        </StackPanel>

                        <TextBlock Text="{Binding FailedFilesForImport, StringFormat='Failed: {0}'}" FontSize="11" TextAlignment="Center" Foreground="#FFB347" Margin="0,0,0,10"/>

                        <TextBlock Text="Overall Progress" FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ProgressPercent}" Height="16" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryMidBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding CurrentImportGroupTitle, StringFormat='Current Shoot: {0}'}" FontSize="12" TextAlignment="Center" Foreground="LightGray" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="Shoot Progress: " FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentGroupFileBeingImported}" FontSize="11" Foreground="LightGray"/>
                            <TextBlock Text=" / " FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding TotalFilesInCurrentGroup}" FontSize="11" Foreground="LightGray"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding CurrentGroupProgressPercent}" Height="10" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="#FF8BC34A" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="Elapsed: " FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding ImportElapsedText}" FontSize="11" Foreground="LightGray" Margin="0,0,12,0"/>
                            <TextBlock Text="ETA: " FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding ImportEtaText}" FontSize="11" Foreground="LightGray" Margin="0,0,12,0"/>
                            <TextBlock Text="Rate: " FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding ImportDataRateText}" FontSize="11" Foreground="LightGray"/>
                        </StackPanel>

                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextAlignment="Center" Foreground="LightGray" TextWrapping="Wrap" MinHeight="30"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Skipped Folders Report Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#AA000000" Visibility="{Binding ShowSkippedFoldersDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Column="1" Grid.Row="1" MinWidth="520" MaxWidth="920" MinHeight="360" MaxHeight="760" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Padding="16" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding SkippedFoldersReportTitle}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="Yellow" Margin="0,0,0,12"/>

                        <Border Grid.Row="1" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4" Padding="8" Background="#11000000">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding SkippedFoldersReportText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0" Background="Transparent" Foreground="LightGray" SelectionBrush="#2A5FFF" SelectionOpacity="0.88"/>
                            </ScrollViewer>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button Content="Copy Report" Command="{Binding CopySkippedFoldersReportCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0"/>
                            <Button Content="Close" Command="{Binding CloseSkippedFoldersReportCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>
