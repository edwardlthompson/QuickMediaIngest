<Window x:Class="QuickMediaIngest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quick Media Ingest" Height="600" Width="900"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Sources -->
        <Border Background="{DynamicResource MaterialDesignCardBackground}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Sources" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="16" FontWeight="Bold"/>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="4" Padding="12" materialDesign:ElevationAssist.Elevation="Dp1">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Sd" VerticalAlignment="Center" Margin="0,0,8,0" Height="20" Width="20"/>
                                    <TextBlock Text="{Binding}" Style="{StaticResource MaterialDesignBody1TextBlock}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <StackPanel Grid.Row="2" Margin="16">
                    <Button Content="Add FTP Source" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"/>
                    <Button Content="Settings &amp; About" Command="{Binding ToggleAboutCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="LightGray" Padding="2" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Update Banner -->
                <RowDefinition Height="Auto"/> <!-- Top Controls -->
                <RowDefinition Height="*"/>    <!-- ScrollViewer -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Update Banner -->
            <Border Background="Yellow" Padding="6" CornerRadius="4" Margin="16,16,16,0" Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Update" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Black"/>
                    <TextBlock Text="A new version is available!" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                    <Button Content="Download" Margin="16,0,0,0" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding DownloadUpdateCommand}" Padding="8,2" Height="24" Background="Black" Foreground="Yellow" FontSize="11"/>
                </StackPanel>
            </Border>
            
            <!-- Top Controls -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16">
                <CheckBox Content="Select All" IsChecked="{Binding SelectAll}" VerticalAlignment="Center" Foreground="Yellow" Margin="0,0,16,0"/>
                <CheckBox Content="Delete After Import" IsChecked="{Binding DeleteAfterImport}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="Yellow"/>
                <Button Content="Import" Margin="16,0,0,2" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding ImportCommand}"/>
            </StackPanel>
            
            <!-- Thumbnail Grid -->
            <ScrollViewer Grid.Row="2" Margin="8">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="8" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}" IsExpanded="False">
                                <Expander.Header>
                                    <Grid Width="Auto">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Bulk Checkbox -->
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Yellow"/>
                                        
                                        <!-- Editable Title -->
                                        <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" Background="Yellow" Foreground="Black" Padding="4,2" BorderThickness="0" MinWidth="120" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                                            <TextBlock Text="📁 " />
                                            <TextBlock Text="{Binding FolderPath}" Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <materialDesign:PackIcon Kind="ImageMultiple" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Items.Count}" FontWeight="Bold"/>
                                            <TextBlock Text=" items" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <Expander.Content>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Margin="8" Width="100" Height="120" Padding="4">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                        <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4" Foreground="Yellow"/>
                                                        <!-- Video Icon Overlay -->
                                                        <materialDesign:PackIcon Kind="Video" Visibility="{Binding IsVideo, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#AA000000" Foreground="White" Width="20" Height="20" Margin="4"/>
                                                        <TextBlock Grid.Row="1" Text="{Binding FileName}" FontSize="10" TextTrimming="CharacterEllipsis" TextAlignment="Center" Margin="2,4"/>
                                                    </Grid>
                                                </materialDesign:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Status Bar -->
            <StatusBar Grid.Row="3" Background="{DynamicResource MaterialDesignDarkBackground}">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" Margin="4,0,16,0"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <ProgressBar Value="{Binding ProgressPercent}" Width="150" Height="10" Style="{StaticResource MaterialDesignLinearProgressBar}" Foreground="{DynamicResource MaterialDesignSecondaryLightMidBrush}"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>

        <!-- Options Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#DD000000" Visibility="{Binding ShowAboutDialog, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="420" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="16" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignPaper}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Settings &amp; Options" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" TextAlignment="Center" Foreground="Yellow" Margin="0,0,0,12"/>
                    
                    <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignTabControl}">
                        
                        <!-- Tab 1: Import Settings -->
                        <TabItem Header="Import">
                            <StackPanel Margin="8">
                                <TextBlock Text="Import Location" FontWeight="Bold" Margin="0,0,0,4" FontSize="13" Foreground="Yellow"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding DestinationRoot}" IsEnabled="False" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="8" materialDesign:HintAssist.Hint="Select Folder"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseDestinationCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Text="File Naming Template" FontWeight="Bold" Margin="0,0,0,4" FontSize="13" Foreground="Yellow"/>
                                <TextBox Text="{Binding NamingTemplate}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="8" materialDesign:HintAssist.Hint="[Date]_[Time]_[Original]"/>
                                <TextBlock Text="Tokens: [Date] (yyyy-MM-dd), [Time] (HH-mm-ss), [Original] (File Name), [Ext] (Extension)" FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="4,2,0,0"/>
                            </StackPanel>
                        </TabItem>

                        <!-- Tab 2: Updates -->
                        <TabItem Header="Updates">
                            <StackPanel Margin="8" VerticalAlignment="Center">
                                <TextBlock Text="Update Checking Frequency" FontWeight="Bold" Margin="0,0,0,8" FontSize="13" Foreground="Yellow"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Interval:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding UpdateIntervalHours}" SelectedValuePath="Hours" DisplayMemberPath="Display" Width="120" Style="{StaticResource MaterialDesignComboBox}"/>
                                </StackPanel>

                                <Button Content="Check for Updates Now" Command="{Binding RefreshUpdateCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="LightGray" Padding="12,2" Height="30" Margin="0,8,0,0"/>
                            </StackPanel>
                        </TabItem>

                        <!-- Tab 3: About -->
                        <TabItem Header="About">
                            <StackPanel Margin="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Quick Media Ingest" FontWeight="Bold" FontSize="14" Foreground="Yellow" TextAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding AppVersion, StringFormat='{}Version: {0}'}" Style="{StaticResource MaterialDesignBody2TextBlock}" TextAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Speedy ingestion pipeline manager." TextAlignment="Center" FontSize="12" Margin="0,0,0,12"/>
                                <Button Content="Visit GitHub" Command="{Binding OpenGitHubCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="Yellow" BorderBrush="Yellow" Padding="12,2" Height="30" Width="120"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <Button Grid.Row="2" Content="Close" Command="{Binding ToggleAboutCommand}" HorizontalAlignment="Center" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,12,0,0"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
