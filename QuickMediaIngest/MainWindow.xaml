<Window x:Class="QuickMediaIngest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QuickMediaIngest"
    xmlns:models="clr-namespace:QuickMediaIngest.Core.Models"
    xmlns:loc="clr-namespace:QuickMediaIngest.Localization"
    xmlns:vm="clr-namespace:QuickMediaIngest.ViewModels"
    xmlns:converters="clr-namespace:QuickMediaIngest.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:controls="clr-namespace:QuickMediaIngest.Controls"
    Title="{loc:Loc Main_WindowTitle}" Height="620" Width="960"
    Icon="QuickMediaIngest.ico"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Background="{DynamicResource MaterialDesignPaper}"
    PreviewMouseWheel="Window_PreviewMouseWheel"
    PreviewKeyDown="Window_PreviewKeyDown"
    SizeChanged="Window_SizeChanged"
    StateChanged="Window_StateChanged"
    Closing="Window_Closing"
    Loaded="MainWindow_Loaded">
    <Window.InputBindings>
        <KeyBinding Key="I" Modifiers="Control" Command="{Binding ImportCommand}" />
        <KeyBinding Key="Q" Modifiers="Control" Command="{Binding QueueImportCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PreflightImportCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshAllSourcesCommand}" />
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="F1" Command="{Binding ShowShortcutsHelpCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:FilterFileTypeToDisplayConverter x:Key="FilterFileTypeToDisplayConverter" />

        <!-- Inverted Boolean to Boolean Converter for disabling during import -->
        <converters:InvertBoolConverter x:Key="BoolToInvertedBoolConverter" />
        
        <!-- Text Converter for Import Button -->
        <converters:BoolToImportingTextConverter x:Key="ImportingTextConverter" />
        <converters:SourceToIconKindConverter x:Key="SourceToIconKindConverter" />

        <Style x:Key="FtpInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="SelectionBrush" Value="#FFE600"/>
            <Setter Property="SelectionOpacity" Value="0.95"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_SelectAll"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>
        </Style>

    </Window.Resources>

    <Grid>
        <TextBlock x:Name="LiveAnnouncementHost"
                   Width="1" Height="1" Margin="-99999,0,0,0"
                   Focusable="False"
                   IsHitTestVisible="False"
                   Visibility="Hidden"
                   Text="{Binding AccessibilityAnnouncement}" />
        <!-- Overlays (dialogs, notifications) -->
        <controls:DialogOverlaysView x:Name="DialogOverlaysViewControl" Grid.ColumnSpan="2" />
        <controls:ImportHistoryOverlayView x:Name="ImportHistoryOverlayViewControl" Grid.ColumnSpan="2" />
        <!-- Main layout: Sidebar + Main Content -->
        <Grid x:Name="MainChromeRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="56" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid x:Name="SidebarHeaderGrid" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="SidebarTitlePanel" Grid.Column="0">
                            <Image x:Name="SidebarLogoCollapsed"
                                   Source="QuickMediaIngest.ico"
                                   Width="20"
                                   Height="20"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,4"/>
                            <TextBlock x:Name="SidebarAppNameText" Text="{loc:Loc Sidebar_AppName}" Style="{StaticResource SidebarTitleTextStyle}"/>
                            <TextBlock x:Name="SidebarAppVersionText" Text="{Binding AppVersion, StringFormat='v{0}'}" Style="{StaticResource AppMutedTextStyle}" Margin="0,4,0,0" />
                            <!-- Center column pins the collapse control when sidebar is narrow; code spans all columns when expanded -->
                            <Grid x:Name="SidebarCollapseToggleHostGrid" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="SidebarCollapseToggle" Grid.Column="0" Grid.ColumnSpan="3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Left"
                                              Style="{StaticResource SidebarRowToggleStyle}"
                                              IsChecked="{Binding SidebarCollapsed, Mode=TwoWay}"
                                              Checked="SidebarCollapseToggle_Toggled"
                                              Unchecked="SidebarCollapseToggle_Toggled"
                                              ToolTip="{loc:Loc Sidebar_CollapseTooltip}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="SidebarHeaderToggleIcon" Kind="DockLeft" Style="{StaticResource SidebarIconStyle}" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="SidebarHeaderLabelText" Text="{loc:Loc Sidebar_Label}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Grid>
                            <Border x:Name="SidebarThemeHeaderBorder" Style="{StaticResource SidebarRowContainerStyle}" Margin="0,10,0,0">
                                <ToggleButton x:Name="ThemeToggle"
                                              Style="{StaticResource SidebarRowToggleStyle}"
                                              Checked="PillToggle_Toggled"
                                              Unchecked="PillToggle_Toggled"
                                              ToolTip="{loc:Loc Theme_Tooltip}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ThemeLightDark" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Theme_Label}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Expanded sidebar content -->
                    <Grid x:Name="SidebarExpandedContent" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <StackPanel x:Name="RibbonTilePanel" Orientation="Horizontal" AllowDrop="True" Margin="12,8,12,8" VerticalAlignment="Top"
                                        DragOver="RibbonTilePanel_DragOver" Drop="RibbonTilePanel_Drop" DragLeave="RibbonTilePanel_DragLeave" />
                            <StackPanel Orientation="Horizontal" Margin="16,8,16,2" HorizontalAlignment="Left">
                                <materialDesign:PackIcon Kind="FolderMultiple" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Sidebar_Sources}" Style="{StaticResource SidebarHeaderTextStyle}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" Margin="12,0,12,10"
                                     VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                                     MaxHeight="180">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <materialDesign:PackIcon Kind="{Binding Converter={StaticResource SourceToIconKindConverter}}" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                        <Expander Grid.Row="1" Margin="12,0,12,8" IsExpanded="{Binding SidebarNotificationsExpanded, Mode=TwoWay}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BellOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Sidebar_Notifications}" Style="{StaticResource SidebarHeaderTextStyle}" />
                                </StackPanel>
                            </Expander.Header>
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="{Binding DeleteAfterImportStatusLine}" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.Warning.Brush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleteAfterImportEnabled}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedFilesStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DestinationStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding RawGroupingStatusText}" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
                                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRawJpegGroupingEnabled}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding KeywordsStatusLine}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding PreviewHealthSummary}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding FtpThumbnailPhaseDetail}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding LastImportSummary}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <Separator Margin="0,8,0,8"/>
                                    <TextBlock Text="{loc:Loc Sidebar_NotificationFeed}" Style="{StaticResource SidebarHeaderTextStyle}" Margin="0,0,0,4"/>
                                    <Button Content="{loc:Loc Notify_ClearFeed}"
                                            Command="{Binding ClearNotificationFeedCommand}"
                                            Style="{StaticResource DialogOutlinedButtonStyle}"
                                            Padding="8,2" Margin="0,0,0,6"/>
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding NotificationFeed}" Margin="0,4,0,0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NotificationFeedLine}">
                                            <StackPanel Margin="0,2,0,2">
                                                <Separator Margin="0,4,0,6" Visibility="{Binding IsSessionDivider, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource AppCaptionTextStyle}">
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UseSuccessAccent}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Theme.Success.Brush}"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Expander>
                    </Grid>

                    <!-- Collapsed icon rail -->
                    <StackPanel x:Name="SidebarCollapsedRail" Grid.Row="1" Visibility="Collapsed" Margin="8,12,8,8">
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Click="ThemeIconButton_Click" ToolTip="{loc:Loc Theme_Tooltip}" Margin="0,0,0,6" AutomationProperties.Name="{loc:Loc Theme_Tooltip}">
                            <materialDesign:PackIcon Kind="ThemeLightDark" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <ItemsControl ItemsSource="{Binding Sources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SidebarChromeIconButtonStyle}"
                                            Tag="{Binding}"
                                            Click="CollapsedSourceButton_Click"
                                            ToolTip="{Binding}"
                                            Margin="0,0,0,4">
                                        <materialDesign:PackIcon Kind="{Binding Converter={StaticResource SourceToIconKindConverter}}" Style="{StaticResource SidebarIconStyle}" Width="18" Height="18"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" ToolTip="{loc:Loc Sidebar_NotificationsIconTooltip}" Margin="0,0,0,6" AutomationProperties.Name="{loc:Loc A11y_NotificationsIcon}">
                            <materialDesign:PackIcon Kind="BellOutline" Style="{StaticResource SidebarIconStyle}" Width="18" Height="18"/></Button>
                    </StackPanel>

                    <!-- Bottom Settings menu -->
                    <Expander x:Name="SettingsExpandedPanel" Grid.Row="2" Margin="8,8,8,12" IsExpanded="{Binding SettingsMenuExpanded, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Sidebar_SettingsHeader}" Style="{StaticResource SidebarSectionTitleTextStyle}" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleSettingsCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Tune" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_Preferences}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding OpenScanExclusionsCommand}"
                                        ToolTip="{loc:Loc Sidebar_ScanExclusionsTooltip}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="FolderRemoveOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Sidebar_ScanExclusions}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleAddFtpCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="LanConnect" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_AddFtpSource}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding OpenImportHistoryCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="History" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_ImportHistory}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                            <Border Style="{StaticResource SidebarRowContainerStyle}">
                                <Button Style="{StaticResource SidebarRowButtonStyle}" Command="{Binding ToggleAboutCommand}">
                                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="InformationOutline" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/><TextBlock Text="{loc:Loc Btn_AboutUpdates}" Style="{StaticResource SidebarHeaderTextStyle}"/></StackPanel>
                                </Button>
                            </Border>
                        </StackPanel>
                    </Expander>
                    <StackPanel x:Name="SettingsCollapsedRail" Grid.Row="2" Visibility="Collapsed" Margin="8,8,8,12">
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleSettingsCommand}" ToolTip="{loc:Loc Btn_Preferences}" Margin="0,0,0,4" AutomationProperties.Name="{loc:Loc Btn_Preferences}"><materialDesign:PackIcon Kind="Tune" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding OpenScanExclusionsCommand}" ToolTip="{loc:Loc Sidebar_ScanExclusionsTooltip}" Margin="0,0,0,4" AutomationProperties.Name="{loc:Loc Sidebar_ScanExclusionsTooltip}"><materialDesign:PackIcon Kind="FolderRemoveOutline" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleAddFtpCommand}" ToolTip="{loc:Loc Btn_AddFtpSource}" Margin="0,0,0,4" AutomationProperties.Name="{loc:Loc Btn_AddFtpSource}"><materialDesign:PackIcon Kind="LanConnect" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding OpenImportHistoryCommand}" ToolTip="{loc:Loc Btn_ImportHistory}" Margin="0,0,0,4" AutomationProperties.Name="{loc:Loc Btn_ImportHistory}"><materialDesign:PackIcon Kind="History" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ToggleAboutCommand}" ToolTip="{loc:Loc Btn_AboutUpdates}" Margin="0,0,0,4" AutomationProperties.Name="{loc:Loc Btn_AboutUpdates}"><materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                        <Button Style="{StaticResource SidebarChromeIconButtonStyle}" Command="{Binding ExitApplicationCommand}" ToolTip="{loc:Loc Btn_Exit_Tooltip}" Margin="0,4,0,0" AutomationProperties.Name="{loc:Loc Btn_Exit_Tooltip}"><materialDesign:PackIcon Kind="ExitToApp" Width="18" Height="18" Style="{StaticResource SidebarIconStyle}"/></Button>
                    </StackPanel>

                    <!-- Exit: expanded sidebar only; collapsed rail uses icon-only Exit (IsChecked=true => sidebar collapsed) -->
                    <Border x:Name="SidebarExitFooterBorder" Grid.Row="3" Margin="8,4,8,12" Padding="0,8,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=SidebarCollapseToggle, Path=IsChecked}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Style="{StaticResource SidebarRowButtonStyle}"
                                Command="{Binding ExitApplicationCommand}"
                                ToolTip="{loc:Loc Btn_Exit_Tooltip}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ExitToApp" Style="{StaticResource SidebarIconStyle}" Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc Btn_Exit}" Style="{StaticResource SidebarHeaderTextStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Sidebar resizer -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Main Content -->
            <Grid Grid.Column="2" Background="{DynamicResource MaterialDesignPaper}" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top action and settings bands -->
                <Border Grid.Row="0"
                        Background="{DynamicResource MenuBackgroundBrush}"
                        BorderBrush="{DynamicResource MenuForegroundBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center" Margin="0,0,0,4">
                            <Border Style="{StaticResource TopBarSectionCardStyle}" ToolTip="{loc:Loc Toolbar_ImportActionsTooltip}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Toolbar_ImportActions}" Style="{StaticResource AppSubheadingTextStyle}" Margin="0,0,0,4"/>
                                    <WrapPanel Style="{StaticResource TopBarControlsWrapStyle}">
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ImportTooltip}"><Button Command="{Binding ImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_ImportTooltip}" Content="{loc:Loc Toolbar_Import}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_QueueTooltip}"><Button Command="{Binding QueueImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_QueueTooltip}" Content="{loc:Loc Toolbar_Queue}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_PreflightTooltip}"><Button Command="{Binding PreflightImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_PreflightTooltip}" Content="{loc:Loc Toolbar_Preflight}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_RetryFailedTooltip}"><Button Command="{Binding RetryFailedImportsCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RetryFailedTooltip}" Content="{loc:Loc Toolbar_RetryFailed}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ResumePendingTooltip}"><Button Command="{Binding ResumePendingImportCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_ResumePendingTooltip}" Content="{loc:Loc Toolbar_ResumePending}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_RefreshTooltip}"><Button Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RefreshTooltip}" Content="{loc:Loc Toolbar_Refresh}"/></Border>
                                        <Border Style="{StaticResource TopBarControlContainerLastStyle}">
                                            <ToggleButton x:Name="DeleteAfterImportCheckBox"
                                                          Content="{loc:Loc Toolbar_DeleteAfterImport}"
                                                          Style="{StaticResource TopBarDangerToggleStyle}"
                                                          IsChecked="{Binding DeleteAfterImport, Mode=TwoWay}"
                                                          Checked="DeleteAfterImportCheckBox_Checked"
                                                          ToolTip="{loc:Loc Toolbar_DeleteAfterImportTooltip}"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource TopBarSectionCardLastStyle}" ToolTip="{loc:Loc Toolbar_ViewSectionTooltip}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Toolbar_ViewSection}" Style="{StaticResource AppSubheadingTextStyle}" Margin="0,0,0,4"/>
                                    <WrapPanel Style="{StaticResource TopBarControlsWrapStyle}">
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_SelectAllTooltip}">
                                            <ToggleButton x:Name="SelectAllCheckBox" Style="{StaticResource TopBarActionToggleStyle}" Checked="SelectAllCheckBox_Checked" Unchecked="SelectAllCheckBox_Unchecked" ToolTip="{loc:Loc Toolbar_SelectAllTooltip}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CheckAll" Width="14" Height="14" Margin="0,0,6,0" Foreground="{DynamicResource MenuForegroundBrush}"/>
                                                    <TextBlock Text="{loc:Loc Toolbar_SelectAll}" Style="{StaticResource AppTextPrimaryStyle}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ExpandAllGroupsTooltip}">
                                            <ToggleButton Style="{StaticResource TopBarActionToggleStyle}" IsChecked="{Binding AllGroupsExpanded, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ArrowExpandVertical" Width="14" Height="14" Margin="0,0,6,0" Foreground="{DynamicResource MenuForegroundBrush}"/>
                                                    <TextBlock Text="{loc:Loc Toolbar_ExpandAllGroups}" Style="{StaticResource AppTextPrimaryStyle}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_GroupByTooltip}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ClockOutline" Width="14" Height="14" Foreground="{DynamicResource MenuForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Slider x:Name="HourIntervalSlider" Minimum="1" Maximum="24" Width="110" Value="{Binding TimeBetweenShootsHours, Mode=TwoWay}" SmallChange="1" IsSnapToTickEnabled="True" ToolTip="{loc:Loc Toolbar_GroupByTooltip}"/>
                                                <Border Background="{DynamicResource MenuForegroundBrush}" CornerRadius="4" Margin="6,0,0,0" Padding="5,2">
                                                    <TextBlock Text="{Binding ElementName=HourIntervalSlider, Path=Value, StringFormat={}{0}h}" Foreground="{DynamicResource MenuBackgroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_ThumbTooltip}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="Magnify" Width="15" Height="15" Foreground="{DynamicResource MenuForegroundBrush}" Margin="0,0,6,0"/>
                                                <materialDesign:PackIcon Kind="Minus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                                                <Slider x:Name="ThumbnailZoomSlider" Minimum="50" Maximum="300" Width="120" Value="{Binding ThumbnailSize, Mode=TwoWay}" Margin="5,0" ToolTip="{loc:Loc Toolbar_ThumbTooltip}"/>
                                                <materialDesign:PackIcon Kind="Plus" Width="12" Height="12" Foreground="{DynamicResource MenuForegroundBrush}" Opacity="0.7" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_FilterTooltip}">
                                            <TextBox x:Name="FilterKeywordTextBox"
                                                     Width="150"
                                                     Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{loc:Loc Toolbar_FilterTooltip}"
                                                     Style="{StaticResource TopBarFieldTextBoxStyle}"
                                                     materialDesign:HintAssist.Hint="{loc:Loc Toolbar_FilterHint}"
                                                     materialDesign:HintAssist.IsFloating="False"/>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerStyle}" ToolTip="{loc:Loc Toolbar_FilterFileTypeTooltip}">
                                            <ComboBox Width="150" Style="{StaticResource TopBarFieldComboBoxStyle}" ItemsSource="{Binding AvailableFileTypes}" SelectedItem="{Binding FilterFileType, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource FilterFileTypeToDisplayConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Border>
                                        <Border Style="{StaticResource TopBarControlContainerLastStyle}" ToolTip="{loc:Loc Toolbar_RebuildPreviewsTooltip}"><Button Command="{Binding ClearThumbnailCacheAndReloadPreviewsCommand}" Style="{StaticResource TopBarActionButtonStyle}" ToolTip="{loc:Loc Toolbar_RebuildPreviewsTooltip}" Content="{loc:Loc Toolbar_RebuildPreviews}"/></Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                    <ItemsControl ItemsSource="{Binding ActiveFilterChips}" Margin="0,0,0,4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="8,2,4,2" Margin="0,0,8,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Style="{StaticResource AppCaptionTextStyle}" Margin="4,0,4,0"/>
                                        <Button Content="✕" FontSize="11"
                                                AutomationProperties.Name="{loc:Loc A11y_RemoveFilterChip}"
                                                Command="{Binding DataContext.RemoveFilterChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource TopBarActionButtonStyle}"
                                                Padding="4,0" MinWidth="22" Height="22"
                                                ToolTip="{loc:Loc Toolbar_RemoveFilterTooltip}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- Grouped Import Items List -->
                <Grid Grid.Row="1" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0,0,0,14" Padding="14" CornerRadius="8"
                            BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                            Background="{DynamicResource Theme.CardBackground.Brush}"
                            Visibility="{Binding ShowPostDeleteRecoveryBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Banner_PostDeleteRecovery}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="{loc:Loc Btn_OpenRecycleBin}" Command="{Binding OpenRecycleBinCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,10,0" Padding="14,8"/>
                                <Button Content="{loc:Loc Btn_Close}" Command="{Binding DismissPostDeleteRecoveryBannerCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Padding="14,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                <ListView ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}" Name="GroupsListView" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="False"
                          Visibility="{Binding ShowShootGroupsList, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12" HorizontalAlignment="Stretch" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="6" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{loc:Loc Menu_SkipFolderFuture}"
                                                  Command="{Binding DataContext.SkipFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding FolderPath}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" MinWidth="120" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="260" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding DataContext.ToggleGroupExpandedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TopBarActionButtonStyle}"
                                                Width="34"
                                                Height="30"
                                                Margin="0,0,8,0"
                                                ToolTip="{loc:Loc Shoot_GroupExpandTooltip}">
                                            <Path Data="M 2 2 L 2 12 L 10 7 Z"
                                                  Fill="{DynamicResource MenuForegroundBrush}"
                                                  Width="12"
                                                  Height="14"
                                                  Stretch="Fill"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="90"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Button>
                                        <TextBox Grid.Column="1" Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontWeight="SemiBold" FontSize="14" BorderThickness="0,0,0,1" Margin="0,0,8,0"
                                                 GotKeyboardFocus="TextBox_SelectAll"
                                                 PreviewMouseLeftButtonDown="TextBox_PreviewMouseLeftButtonDown"
                                                 materialDesign:HintAssist.Hint="{loc:Loc Shoot_HintName}"
                                                 materialDesign:HintAssist.IsFloating="False"/>
                                        <Rectangle Grid.Column="2" Width="1" Margin="6,2,10,2" VerticalAlignment="Stretch"
                                                   Fill="{DynamicResource MaterialDesignDivider}" />
                                        <TextBox Grid.Column="3" Text="{Binding KeywordsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36" MaxHeight="96"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontSize="12"
                                                 materialDesign:HintAssist.Hint="{loc:Loc Shoot_HintKeywords}"
                                                 materialDesign:HintAssist.IsFloating="False"/>
                                        <StackPanel Grid.Column="4" Orientation="Vertical" Margin="4,0,10,0">
                                            <CheckBox Content="{loc:Loc Shoot_SelectShoot}" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top"/>
                                            <Button Content="{loc:Loc Shoot_ToggleStackLayout}"
                                                    Command="{Binding DataContext.ToggleShootStackExpandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource TopBarActionButtonStyle}"
                                                    FontSize="11"
                                                    Margin="0,6,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="4,0"
                                                    Visibility="{Binding DataContext.GroupRawAndRenderedPairs, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="{loc:Loc Shoot_ToggleStackTooltip}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="5">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_SourceFolderLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding FolderPath}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_StartLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding StartDate, StringFormat=yyyy-MM-dd HH:mm}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_EndLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding EndDate, StringFormat=yyyy-MM-dd HH:mm}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{loc:Loc Shoot_FilesLabel}" Margin="0,0,6,0"/>
                                                <TextBlock Style="{StaticResource AppBodyTextStyle}" Text="{Binding Items.Count}"/>
                                            </StackPanel>
                                            <Button Content="{loc:Loc Shoot_IgnoreFolder}"
                                                    Command="{Binding DataContext.SkipFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding FolderPath}"
                                                    Style="{StaticResource DialogOutlinedButtonStyle}"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    ToolTip="{loc:Loc Shoot_IgnoreFolderTooltip}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Separator Margin="0,4,0,8" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <ItemsControl ItemsSource="{Binding Items}" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,8,8" Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="4" Padding="2">
                                                        <Grid MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="Uniform"
                                                                   SnapsToDevicePixels="True">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailPreviewStatus}" Value="{x:Static models:ThumbnailPreviewStatus.Failed}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <Border Background="#66000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ThumbnailPreviewStatus}" Value="{x:Static models:ThumbnailPreviewStatus.Failed}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <materialDesign:PackIcon Kind="ImageBroken" Width="28" Height="28" Foreground="#FFF5F5F5" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{loc:Loc Preview_Failed}" FontSize="10" Foreground="#FFF5F5F5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <CheckBox Content="{Binding PreviewLabel}" IsChecked="{Binding IsSelected, Mode=TwoWay}" FontSize="11" Margin="0,2,0,0"
                                                              Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Border Padding="28"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        Background="{DynamicResource Theme.CardBackground.Brush}"
                        Visibility="{Binding ShowShootListEmptyPlaceholder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="440">
                        <StackPanel Visibility="{Binding ShowEmptyNoSourcesPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_NoSourcesTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" HorizontalAlignment="Left" Padding="16,8"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyFilterPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_FilterNoMatchTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="{loc:Loc Empty_ClearFilters}" Command="{Binding ClearFiltersCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" HorizontalAlignment="Left" Padding="16,8"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyFtpFailurePanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_FtpFailureTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <TextBlock Text="{loc:Loc Empty_FtpFailureBody}" Style="{StaticResource AppBodyTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{loc:Loc Toolbar_Refresh}" Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_Close}" Command="{Binding DismissFtpProblemHintsCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowEmptyScanPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{loc:Loc Empty_NoFilesTitle}" Style="{StaticResource AppSubheadingTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{loc:Loc Toolbar_Refresh}" Command="{Binding RefreshAllSourcesCommand}" Style="{StaticResource DialogPrimaryButtonStyle}" Margin="0,0,10,0" Padding="16,8"/>
                                <Button Content="{loc:Loc Btn_AddFtpSource}" Command="{Binding ToggleAddFtpCommand}" Style="{StaticResource DialogOutlinedButtonStyle}" Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                    </Grid>
                </Grid>
                <!-- Details Panel for Selected Group -->
                <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}" Padding="16" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Details_GroupDetails}" Style="{StaticResource AppHeadingTextStyle}" Margin="0,0,0,8"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                        <ItemsControl ItemsSource="{Binding SelectedGroup.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Thumbnail}"
                                               MaxWidth="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               MaxHeight="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding FileName}" Width="180"/>
                                        <TextBlock Text="{Binding FileType}" Width="60"/>
                                        <TextBlock Text="{Binding FileSize, StringFormat={}{0:N0} bytes}" Width="100"/>
                                        <TextBlock Text="{Binding DateTaken, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,1,0,0" Padding="10,6">
                    <DockPanel LastChildFill="True">
                        <ProgressBar DockPanel.Dock="Left"
                                     Width="170"
                                     Height="16"
                                     Margin="0,0,10,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressPercent}" />

                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MenuForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ScanProgressMessage}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Theme.TextSecondary.Brush}"
                                       Visibility="{Binding ShowScanProgressDialog, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
        <!-- Settings: root-level overlay so VisualBrush blur matches other modals (not a child of MainChromeRoot) -->
        <controls:PreferencesOverlayView x:Name="PreferencesOverlayViewControl" />

        <!-- Scan exclusions: root-level overlay (same blur as other modals) -->
        <controls:ScanExclusionsOverlayView x:Name="ScanExclusionsOverlayViewControl" />
    </Grid>
</Window>

