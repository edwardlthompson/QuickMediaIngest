<Window x:Class="QuickMediaIngest.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="460"
        Height="220">
    <Border CornerRadius="14"
            Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                       Width="80" Height="80"
                       Margin="0,0,20,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Quick Media Ingest"
                               Style="{StaticResource AppHeadingLargeTextStyle}"
                               FontSize="26"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="Starting up..."
                               Style="{StaticResource AppMutedTextStyle}"
                               FontSize="14"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>

            <ProgressBar Grid.Row="1"
                         Height="4"
                         IsIndeterminate="True"
                         Foreground="{DynamicResource AppAccentBrush}"
                         Background="{DynamicResource MaterialDesignDivider}"
                         BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
