<Window x:Class="QuickMediaIngest.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="460"
        Height="220">
    <Border CornerRadius="14"
            Background="#FF1E1E1E"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Quick Media Ingest"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#FFF6F6F6"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Starting up..."
                           FontSize="14"
                           Margin="0,8,0,0"
                           Foreground="#FFBDBDBD"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         Height="4"
                         IsIndeterminate="True"
                         Foreground="#FFFFEB3B"
                         Background="#33111111"
                         BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
